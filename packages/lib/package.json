{
  "name": "@voyd-lang/lib",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "files": [
    "dist",
    "assets"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/lib/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./voyd.tmLanguage.json": "./assets/voyd.tmLanguage.json",
    "./voyd-markdown-injection.json": "./assets/voyd-markdown-injection.json",
    "./package.json": "./package.json",
    "./*.js": {
      "types": "./dist/*.d.ts",
      "development": "./src/lib/*.ts",
      "import": "./dist/*.js",
      "default": "./dist/*.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "development": "./src/lib/*.ts",
      "import": "./dist/*.js",
      "default": "./dist/*.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run --config ../../vitest.config.ts src/lib/__tests__",
    "lint": "echo 'no lint configured'",
    "prepack": "npm run clean && npm run build"
  },
  "dependencies": {
    "@msgpack/msgpack": "^3.1.2",
    "@voyd-lang/std": "^0.1.0",
    "binaryen": "^125.0.0"
  }
}
