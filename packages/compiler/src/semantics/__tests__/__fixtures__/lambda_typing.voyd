fn applyTwice(f: fn(i32) -> i32, value: i32) -> i32
  f(f(value))

fn makeIncrementer(delta: i32) -> (fn(i32) -> i32)
  (value) => value + delta

fn applyWithoutParameter(callback: fn(i32) -> i32) -> i32
  callback(1)

fn applyLeadingParameter(callback: fn(i32, i32, i32) -> i32) -> i32
  callback(2, 3, 4)

pub fn main() -> i32
  let result = applyTwice((x) => x * 2, 3)
  let inc = makeIncrementer(1)
  let trimmed = result.((n) => n - 1)
  let no_parameter = applyWithoutParameter(() => 5)
  let leading_parameter = applyLeadingParameter((first) => first)
  trimmed + inc(4) + no_parameter + leading_parameter
