fn pick(flag: bool, mapper: fn(i32) -> i32) -> i32
  mapper(1)

fn pick(flag: i32, mapper: fn(bool) -> i32) -> i32
  mapper(false)

fn invoke(mapper: fn() -> i32) -> i32
  mapper()

fn invoke(mapper: fn(i32) -> i32) -> i32
  mapper(1)

pub fn main() -> i32
  pick(true, x => x + 1)

pub fn exact_lambda_arity() -> i32
  invoke(() => 4)
