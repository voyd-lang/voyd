use std::array::Array
use std::msgpack::{ MsgPack, make_array, make_i32, make_string }
use std::string::type::{ new_string }

eff Exchange
  roundtrip(resume, value: MsgPack) -> MsgPack

fn build_payload(): () -> MsgPack
  let ~items = Array<MsgPack>::with_capacity(3)
  items.push(make_i32(1))
  items.push(make_string("hi"))
  let ~nested = Array<MsgPack>::with_capacity(2)
  nested.push(make_i32(2))
  nested.push(make_i32(3))
  items.push(make_array(nested))
  make_array(items)

pub fn main(): Exchange -> MsgPack
  let payload = build_payload()
  Exchange::roundtrip(payload)
