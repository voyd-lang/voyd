use std::enums::{ enum }
use std::vx::all

obj Model {
  count: i32
}

enum Msg
  Increment

pub fn app() -> Program<Model, Msg>
  program({ init, step, view })

fn init() -> Model
  Model { count: 0 }

fn step(model: Model, msg: Msg) -> Program<Model, Msg>
  match(msg)
    Msg::Increment:
      next(Model { count: model.count + 1 })

fn view(model: Model) -> Html<Msg>
  <button on_click={Msg::Increment {}}>
    Count
  </button>

pub fn echo_command(command: Cmd<Msg>) -> Cmd<Msg>
  command

pub fn add(a: i32, b: i32) -> i32
  a + b
