use std::enums::{ enum }
use std::vx::all

obj MaybeCount {
  value?: i32
}

enum Msg
  Noop

pub fn app() -> Program<MaybeCount, Msg>
  program<MaybeCount, Msg>(
    init: init,
    update: update,
    view: view
  )

fn init() -> MaybeCount
  MaybeCount {}

fn update(model: MaybeCount, _msg: Msg) -> Program<MaybeCount, Msg>
  program<MaybeCount, Msg>(model: model)

fn view(_model: MaybeCount) -> Html<Msg>
  <div></div>
