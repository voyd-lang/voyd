use std::enums::{ enum }
use std::vx::all

obj CallbackModel {
  apply: fn() -> i32
}

enum Msg
  Noop

pub fn app() -> Program<CallbackModel, Msg>
  program<CallbackModel, Msg>(
    init: init,
    step: step,
    view: view
  )

fn init() -> CallbackModel
  CallbackModel { apply: read_value }

fn step(model: CallbackModel, _msg: Msg) -> Program<CallbackModel, Msg>
  next<CallbackModel, Msg>(model)

fn view(_model: CallbackModel) -> Html<Msg>
  <div></div>

fn read_value() -> i32
  1
