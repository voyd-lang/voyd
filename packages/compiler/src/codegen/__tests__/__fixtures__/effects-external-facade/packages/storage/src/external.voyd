use std::array::Array
use std::optional::all
use std::result::types::all
use std::string::type::String

pub obj WireRecord {
  api namespace: String,
  api values: Array<i32>
}

pub obj WireError {
  api message: String
}

@external(id: "example:storage/document@1")
pub eff Document
  roundtrip(
    tail,
    namespace: String,
    record: WireRecord,
    current: Optional<WireRecord>
  ) -> Result<Array<WireRecord>, WireError>
  inspect(tail, namespace: String) -> Result<WireRecord, WireError>
