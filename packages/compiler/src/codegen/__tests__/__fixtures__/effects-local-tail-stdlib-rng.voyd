use std::number::cast::to_i64
use std::random::LocalRng
use std::range::{ Range }

eff RenderCtx
  rand_f64(tail) -> f64
  rand_f64(tail, range: Range<f64>) -> f64

val Triple {
  x: f64,
  y: f64,
  z: f64
}

fn random_triple(range: Range<f64>): RenderCtx -> Triple
  Triple {
    x: RenderCtx::rand_f64(range),
    y: RenderCtx::rand_f64(range),
    z: RenderCtx::rand_f64(range)
  }

pub fn rand_plain(): () -> f64
  let ~rng = LocalRng::seeded(to_i64(42))

  try open
    RenderCtx::rand_f64()
  RenderCtx::rand_f64(tail):
    tail(rng.random_f64())
  RenderCtx::rand_f64(tail, range: Range<f64>):
    tail(rng.random_f64(range))

pub fn rand_range(): () -> f64
  let ~rng = LocalRng::seeded(to_i64(42))

  try open
    RenderCtx::rand_f64(0.0..0.5)
  RenderCtx::rand_f64(tail):
    tail(rng.random_f64())
  RenderCtx::rand_f64(tail, range: Range<f64>):
    tail(rng.random_f64(range))

pub fn rand_triple_sum(): () -> f64
  let ~rng = LocalRng::seeded(to_i64(42))

  try open
    let value = random_triple(0.0..0.5)
    value.x + value.y + value.z
  RenderCtx::rand_f64(tail):
    tail(rng.random_f64())
  RenderCtx::rand_f64(tail, range: Range<f64>):
    tail(rng.random_f64(range))
