pub fn get_context<T: IntoResponse<T>>(
  app: AppBuild,
  path: StringSlice,
  handler: fn(Context) : (open) -> Option<T>
) -> AppBuild
  app.route_context(path, method: Method::Get {}, handler: (ctx: Context) -> Response =>
    let result = handler(ctx)
    match(result)
      Some<T> { value }:
        to_response<T>(value)
      None:
        Response::not_found().empty()
  )

