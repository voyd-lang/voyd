pub fn route<I, P: FromBody<I>, R: IntoResponse<R>>(
  app: AppBuild,
  path: StringSlice,
  { method: Method, body: P, limit: BodyLimit },
  handler: fn(I) : (open) -> R
) -> AppBuild
  app.route_context(path, method: method, handler: (ctx: Context) -> Response =>
    match(body_limit_rejection(ctx, limit))
      Some<Response> { value }:
        value
      None:
        match(body.extract_body(ctx.request))
          Ok<I> { value }:
            to_response<R>(handler(value))
          Err<Rejection> { error }:
            ctx.reject(error)
  )

