) -> AppBuild
  app.route_context(path, method: method, handler: (ctx: Context) -> Response =>
    match(body.extract_body(ctx.request))
      Ok<I> { value }:
        json_dto<R>(handler(value))
      Err<Rejection> { error }:
        ctx.reject(error)
  )

pub fn route_body_dto<I, P: FromBody<I>, R>(
  app: AppBuild,
  path: StringSlice,
  { method: Method, body: P, timeout: TimeoutPolicy },
  handler: fn(I) : (open) -> R
) -> AppBuild
  app.route_context(path, method: method, handler: (ctx: Context) -> Response =>
    run_with_timeout(timeout) do:
      match(body.extract_body(ctx.request))
        Ok<I> { value }:
          json_dto<R>(handler(value))
        Err<Rejection> { error }:
          ctx.reject(error)
  )

