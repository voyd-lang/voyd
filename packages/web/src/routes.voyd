pub fn route_unit<T: IntoResponse<T>>(
  app: AppBuild,
  path: StringSlice,
  { method: Method },
  handler: fn() : (open) -> Option<T>
) -> AppBuild
  app.route_context(path, method: method, handler: (_ctx: Context) -> Response =>
    let result = handler()
    match(result)
      Some<T> { value }:
        to_response<T>(value)
      None:
        Response::not_found().empty()
  )

