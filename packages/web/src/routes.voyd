pub fn get_context<T: IntoResponse<T>, E: IntoResponse<E>>(
  app: AppBuild,
  path: StringSlice,
  handler: fn(Context) : (open) -> Result<T, E>
) -> AppBuild
  record_operation(app, path, Method::Get {}, (ctx: Context) -> Response =>
    let result = handler(ctx)
    to_response<T, E>(result)
  , result_operation<T, E>(operation().with_opaque_response()))

pub fn get_context<T: IntoResponse<T>>(
  app: AppBuild,
  path: StringSlice,
  handler: fn(Context) : (open) -> Option<T>
) -> AppBuild
  record_operation(app, path, Method::Get {}, (ctx: Context) -> Response =>
    let result = handler(ctx)
    match(result)
      Some<T> { value }:
        typed_response<T>(value)
      None:
        Response::not_found().empty()
  , option_operation<T>(operation().with_opaque_response()))

pub fn get_unit(
  app: AppBuild,
  path: StringSlice,
  handler: fn() : (open) -> Response
) -> AppBuild
  record_operation(app, path, Method::Get {}, (_ctx: Context) -> Response =>
    handler()
  , operation().with_opaque_response())

