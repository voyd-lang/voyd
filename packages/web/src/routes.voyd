pub fn route<S, A: FromAuth<S>, R: IntoResponse<R>>(
  app: AppBuild,
  path: StringSlice,
  { method: Method, auth: A },
  handler: fn(S) : (open) -> R
) -> AppBuild
  record_operation(app, path, method, (ctx: Context) -> Response =>
    match(auth.extract_auth(ctx.request))
      Ok<S> { value }:
        typed_response<R>(handler(value))
      Err<Rejection> { error }:
        ctx.reject(error)
  , operation().with_responses(inferred_responses<R>()))

