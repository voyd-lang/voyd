pub fn route_unit(
  app: AppBuild,
  path: StringSlice,
  { method: Method },
  handler: fn() : (open) -> String
) -> AppBuild
  record_operation(app, path, method, (_ctx: Context) -> Response =>
    let result = handler()
    to_response(result)
  , operation().with_responses(inferred_responses<String>()))

