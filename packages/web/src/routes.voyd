) -> AppBuild
  app.route_context(path, method: method, handler: (ctx: Context) -> Response =>
    match(body.extract_body(ctx.request))
      Ok<I> { value }:
        result_dto_json<T, E>(handler(value))
      Err<Rejection> { error }:
        ctx.reject(error)
  )

pub fn route_body_result_dto<I, P: FromBody<I>, T, E: IntoResponse<E>>(
  app: AppBuild,
  path: StringSlice,
  { method: Method, body: P, timeout: TimeoutPolicy },
  handler: fn(I) : (open) -> Result<T, E>
) -> AppBuild
