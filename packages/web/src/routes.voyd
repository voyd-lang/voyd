pub fn route_params_headers<P, H, R: IntoResponse<R>>(
  app: AppBuild,
  path: StringSlice,
  { method: Method },
  handler: fn(P, H) : (open) -> R
) -> AppBuild
  record_operation(app, path, method, (ctx: Context) -> Response =>
    match(extract_params<P>(ctx.route.params))
      Err<Rejection> { error }:
        ctx.reject(error)
      Ok<P> { value: params }:
        match(extract_headers<H>(ctx.request.headers))
          Ok<H> { value: headers }:
            typed_response<R>(handler(params, headers))
          Err<Rejection> { error }:
            ctx.reject(error)
  , params_headers_operation<P, H>().with_responses(inferred_responses<R>()))

pub fn route_params_headers<P, H, R: IntoResponse<R>>(
  app: AppBuild,
  path: StringSlice,
  { method: Method, timeout: TimeoutPolicy },
