) -> AppBuild
  record_operation(app, path, Method::Get {}, (ctx: Context) -> Response =>
    match(extract_params<P>(ctx.route.params))
      Ok<P> { value }:
        match(handler(value))
          Some<T> { value }:
            typed_response<T>(value)
          None:
            Response::not_found().empty()
      Err<Rejection> { error }:
        ctx.reject(error)
  , option_operation<T>(params_operation<P>()))

