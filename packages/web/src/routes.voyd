pub obj TimeoutPolicy {
  api duration: Duration
}

pub fn timeout(duration: Duration) -> TimeoutPolicy
  TimeoutPolicy { duration: duration }

pub fn timeout_millis(millis: i64) -> TimeoutPolicy
  timeout(Duration::from_millis(millis))

pub fn timeout_millis(millis: i32) -> TimeoutPolicy
  timeout(Duration::from_millis(cast::to_i64(millis)))

fn gateway_timeout() -> Response
  match(Status::from(504))
    Ok<Status> { value }:
      Response::new(status: value).text("route timed out".as_slice())
    Err:
      Response::internal_server_error().text("route timed out".as_slice())

fn run_with_timeout(
  timeout: TimeoutPolicy,
  work: fn() : (open) -> Response
): (task::TaskRuntime, Time, open) -> Response
  let worker = task::spawn do:
    work()
  let timer = time::set_timeout(timeout.duration) do:
    task::cancel<Response>(worker)
  match(task::join(worker))
    Ok<Response> { value }:
      let _ = task::cancel<bool>(timer)
      value
    Err { error }:
      let _ = task::cancel<bool>(timer)
      panic(error.message)
      Response::internal_server_error()
    Cancelled:
      gateway_timeout()

fn body_limit_rejection(ctx: Context, limit: BodyLimit): () -> Option<Response>
  if ctx.request.body.len() > limit.max_bytes:
    Some<Response> {
      value: ctx.reject(Rejection::payload_too_large("request body exceeds configured limit".as_slice()))
    }
  else:
    None {}

fn with_params_query<P, Q>(
  ctx: Context,
  work: fn(P, Q) : (open) -> Response
): (open) -> Response
  let query_source = ctx.query()
  match(extract_params<P>(ctx.route.params))
    Err<Rejection> { error }:
      ctx.reject(error)
    Ok<P> { value: params }:
      match(extract_query<Q>(query_source))
        Ok<Q> { value: query }:
          work(params, query)
        Err<Rejection> { error }:
          ctx.reject(error)

pub fn get_context(
  app: AppBuild,
  path: StringSlice,
  handler: Handler
) -> AppBuild
  app.route_context(path, method: Method::Get {}, handler: handler)

pub fn get_context<R: IntoResponse<R>>(
  app: AppBuild,
  path: StringSlice,
  { timeout: TimeoutPolicy },
  handler: fn(Context) : (open) -> R
) -> AppBuild
  route_context(app, path, method: Method::Get {}, timeout: timeout, handler)

pub fn get_context(
  app: AppBuild,
  path: StringSlice,
  handler: fn(Context) : (open) -> String
) -> AppBuild
  app.route_context(path, method: Method::Get {}, handler: (ctx: Context) -> Response =>
    let result = handler(ctx)
    to_response(result)
  )

