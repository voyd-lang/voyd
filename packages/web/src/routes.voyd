pub fn get<P>(
  app: AppBuild,
  path: StringSlice,
  handler: fn(P) : (open) -> Response
) -> AppBuild
  app.route_context(path, method: Method::Get {}, handler: (ctx: Context) -> Response =>
    match(extract_params<P>(ctx.route.params))
      Ok<P> { value }:
        handler(value)
      Err<Rejection> { error }:
        ctx.reject(error)
  )

