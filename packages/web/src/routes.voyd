/// Applies documentation to a concrete route built through any free helper.
pub fn with_route_docs(
  app: AppBuild,
  path: StringSlice,
  { method: Method, docs: RouteDocs }
) -> AppBuild
  app.with_route_docs(path, method: method, docs: docs)

fn with_params_query<P, Q>(
  ctx: Context,
  work: fn(P, Q) : (open) -> Response
): (open) -> Response
  let query_source = ctx.query()
  match(extract_params<P>(ctx.route.params))
    Err<Rejection> { error }:
      ctx.reject(error)
    Ok<P> { value: params }:
      match(extract_query<Q>(query_source))
        Ok<Q> { value: query }:
          work(params, query)
        Err<Rejection> { error }:
          ctx.reject(error)

fn record_operation(
  app: AppBuild,
  path: StringSlice,
  method: Method,
  handler: Handler,
  operation: Operation
) -> AppBuild
  app.record_operation(path, method: method, handler: handler, operation: operation)

fn body_operation<I, P: FromBody<I>>(body: P) -> Operation
  extractor_operation(body.openapi_request())

fn typed_body_operation<I, P: FromBody<I>, R: IntoResponse<R>>(body: P) -> Operation
  body_operation<I, P>(body).with_responses(inferred_responses<R>())

fn json_body_operation<I, P: FromBody<I>, R>(body: P) -> Operation
  body_operation<I, P>(body).with_responses(json_responses<R>())

fn result_json_body_operation<I, P: FromBody<I>, T, E: IntoResponse<E>>(body: P) -> Operation
  body_operation<I, P>(body).with_responses(result_responses<Json<T>, E>())


fn json_operation<T>(base: Operation) -> Operation
  base.with_responses(json_responses<T>())

fn result_operation<T: IntoResponse<T>, E: IntoResponse<E>>(base: Operation) -> Operation
  base.with_responses(result_responses<T, E>())

fn result_json_operation<T, E: IntoResponse<E>>(base: Operation) -> Operation
  base.with_responses(result_responses<Json<T>, E>())

fn option_operation<T: IntoResponse<T>>(base: Operation) -> Operation
  base.with_responses(option_responses<T>())

fn opaque_operation(base: Operation) -> Operation
  base.with_opaque_response()

fn query_operation<Q>() -> Operation
  opaque_operation(operation().with_query<Q>())

fn headers_operation<H>() -> Operation
  opaque_operation(operation().with_headers<H>())

fn cookies_operation<C>() -> Operation
  opaque_operation(operation().with_cookies<C>())

fn params_operation<P>() -> Operation
  opaque_operation(operation().with_path_params<P>())

fn params_query_operation<P, Q>() -> Operation
  opaque_operation(operation().with_path_params<P>().with_query<Q>())

fn params_headers_operation<P, H>() -> Operation
  opaque_operation(operation().with_path_params<P>().with_headers<H>())

fn query_headers_operation<Q, H>() -> Operation
  opaque_operation(operation().with_query<Q>().with_headers<H>())

fn params_query_headers_operation<P, Q, H>() -> Operation
  opaque_operation(
    operation().with_path_params<P>().with_query<Q>().with_headers<H>()
  )

pub fn get_context(
  app: AppBuild,
  path: StringSlice,
  handler: Handler
) -> AppBuild
  app.route_context(path, method: Method::Get {}, handler: handler)

pub fn get_context<R: IntoResponse<R>>(
  app: AppBuild,
  path: StringSlice,
  { timeout: TimeoutPolicy },
  handler: fn(Context) : (open) -> R
) -> AppBuild
  route_context(app, path, method: Method::Get {}, timeout: timeout, handler)

pub fn get_context(
  app: AppBuild,
  path: StringSlice,
  handler: fn(Context) : (open) -> String
) -> AppBuild
  record_operation(app, path, Method::Get {}, (ctx: Context) -> Response =>
    let result = handler(ctx)
    to_response(result)
  , operation().with_opaque_response().with_responses(inferred_responses<String>()))

