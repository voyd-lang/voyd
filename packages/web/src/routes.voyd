pub fn post<I, P: FromBody<I>>(
  app: AppBuild,
  path: StringSlice,
  { body: P },
  handler: fn(I) : (open) -> Response
) -> AppBuild
  app.route_context(path, method: Method::Post {}, handler: (ctx: Context) -> Response =>
    match(body.extract_body(ctx.request))
      Ok<I> { value }:
        handler(value)
      Err<Rejection> { error }:
        ctx.reject(error)
  )

