pub fn route_params_query_headers_context<P, Q, H, R: IntoResponse<R>>(
  app: AppBuild,
  path: StringSlice,
  { method: Method, timeout: TimeoutPolicy },
  handler: fn(P, Q, H, Context) : (open) -> R
) -> AppBuild
  record_operation(app, path, method, (ctx: Context) -> Response =>
    run_with_timeout(timeout) do:
