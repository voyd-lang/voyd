pub fn get<S, A: FromAuth<S>, R: IntoResponse<R>>(
  app: AppBuild,
  path: StringSlice,
  { auth: A },
  handler: fn(S) : (open) -> R
) -> AppBuild
  record_operation(app, path, Method::Get {}, (ctx: Context) -> Response =>
    match(auth.extract_auth(ctx.request))
      Ok<S> { value }:
        typed_response<R>(handler(value))
      Err<Rejection> { error }:
        ctx.reject(error)
  , operation().with_opaque_response().with_responses(inferred_responses<R>()))

pub fn get<S, A: FromAuth<S>, R: IntoResponse<R>>(
  app: AppBuild,
  path: StringSlice,
  { auth: A },
  handler: fn(S, Context) : (open) -> R
) -> AppBuild
  record_operation(app, path, Method::Get {}, (ctx: Context) -> Response =>
    match(auth.extract_auth(ctx.request))
      Ok<S> { value }:
        typed_response<R>(handler(value, ctx))
      Err<Rejection> { error }:
        ctx.reject(error)
  , operation().with_opaque_response().with_responses(inferred_responses<R>()))

pub fn get<S, A: FromAuth<S>, R: IntoResponse<R>>(
  app: AppBuild,
  path: StringSlice,
  { auth: A, timeout: TimeoutPolicy },
  handler: fn(S) : (open) -> R
) -> AppBuild
  record_operation(app, path, Method::Get {}, (ctx: Context) -> Response =>
    run_with_timeout(timeout) do:
      match(auth.extract_auth(ctx.request))
        Ok<S> { value }:
          typed_response<R>(handler(value))
        Err<Rejection> { error }:
          ctx.reject(error)
  , operation().with_opaque_response().with_responses(inferred_responses<R>()))

