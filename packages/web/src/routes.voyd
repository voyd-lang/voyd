          ctx.reject(error)
        Ok<P> { value: params }:
          match(extract_query<Q>(ctx.query()))
            Err<Rejection> { error }:
              ctx.reject(error)
            Ok<Q> { value: query }:
              match(extract_headers<H>(ctx.request.headers))
                Ok<H> { value: headers }:
                  typed_response<R>(handler(params, query, headers, ctx))
                Err<Rejection> { error }:
                  ctx.reject(error)
  , params_query_headers_operation<P, Q, H>().with_responses(inferred_responses<R>()))

