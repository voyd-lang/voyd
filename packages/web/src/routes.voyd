pub fn route_context<T: IntoResponse<T>>(
  app: AppBuild,
  path: StringSlice,
  { method: Method },
  handler: fn(Context) : (open) -> Option<T>
) -> AppBuild
  app.route_context(path, method: method, handler: (ctx: Context) -> Response =>
    match(handler(ctx))
      Some<T> { value }:
        to_response<T>(value)
      None:
        Response::not_found().empty()
  )

