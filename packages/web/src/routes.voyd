pub fn post<I, P: FromBody<I>>(
  app: AppBuild,
  path: StringSlice,
  { body: P, auth: RequiredSession },
  handler: fn(I, String) : (open) -> Response
) -> AppBuild
  auth
  record_operation(app, path, Method::Post {}, (ctx: Context) -> Response =>
    match(body.extract_body(ctx.request))
      Err<Rejection> { error }:
        ctx.reject(error)
      Ok<I> { value: input }:
