) -> AppBuild
  app.route_context(path, method: method, handler: (ctx: Context) -> Response =>
    match(extract_params<P>(ctx.route.params))
      Err<Rejection> { error }:
        ctx.reject(error)
      Ok<P> { value: params }:
        match(extract_query<Q>(ctx.query()))
          Err<Rejection> { error }:
            ctx.reject(error)
          Ok<Q> { value: query }:
            match(extract_headers<H>(ctx.request.headers))
