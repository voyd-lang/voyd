pub fn get<P>(
  app: AppBuild,
  path: StringSlice,
  handler: fn(P) : (open) -> Response
) -> AppBuild
  record_operation(app, path, Method::Get {}, (ctx: Context) -> Response =>
    match(extract_params<P>(ctx.route.params))
      Ok<P> { value }:
        handler(value)
      Err<Rejection> { error }:
        ctx.reject(error)
  , params_operation<P>())

