  let value = route_headers<HeaderInput, Text>(
    app(openapi: { title: "Headers", version: "1" }),
    "/headers",
    method: Method::Get {},
    header_reply
  )
  require_contains(openapi_string(value), "\"in\":\"header\"".as_slice(), "missing standalone header contract")

test "free cookie routes preserve contracts":
