    "/limited-text",
    body: limited(text_body(), limit: body_limit(1024)),
    handler: text_body_reply
  )
  require_contains(openapi_string(value), "\"text/plain\"".as_slice(), "missing standalone limited text contract")

test "limited byte bodies preserve their request contract":
  let value = app(openapi: { title: "Bodies", version: "1" }).post(
    "/limited-bytes",
    body: limited(bytes(), limit: body_limit(1024)),
    handler: bytes_body_reply
  )
  require_contains(openapi_string(value), "\"application/octet-stream\"".as_slice(), "missing standalone limited bytes contract")

test "custom extractors can publish a separate request contract":
  let value = app(openapi: { title: "Custom extractor", version: "1" }).post(
    "/custom-body",
    body: CustomTextBody {},
    handler: custom_body_reply,
    docs: route_docs(responses: [
      openapi_json_response<AutomaticArticle>(
        status: 207,
        description: "Custom extractor override"
      )
    ])
  )
  let rendered = openapi_string(value)
  require_contains(rendered, "\"text/plain\"".as_slice(), "missing custom extractor contract")
  require_contains(rendered, "\"207\"".as_slice(), "custom extractor RouteDocs override was not applied")

test "multipart extractors publish an honest opaque multipart body":
  let value = app(openapi: { title: "Multipart", version: "1" }).post(
    "/upload",
    body: multipart(),
    handler: multipart_reply
  )
  require_contains(openapi_string(value), "\"multipart/form-data\"".as_slice(), "missing multipart contract")

test "automatic schemas preserve recursion and distinct same-named DTOs":
  let value = app(openapi: { title: "Schema identity", version: "1" })
    .post<DocumentedRecursivePair>("/recursive", body: json_body(), handler: recursive_reply)
    .get("/duplicate-a", handler: duplicate_a_reply)
    .get("/duplicate-b", handler: duplicate_b_reply)
  let rendered = openapi_string(value)
  require_contains(rendered, "DocumentedRecursivePair_".as_slice(), "missing recursive component")
  require_contains(rendered, "\"left\"".as_slice(), "first same-named DTO was overwritten")
  require_contains(rendered, "\"right\"".as_slice(), "second same-named DTO was overwritten")
  require_contains(rendered, "Next recursive node when present.".as_slice(), "recursive field documentation was omitted")
  let without_comments = openapi_string(value, include_doc_comments: false)
  require_not_contains(without_comments, "Next recursive node when present.".as_slice(), "recursive field documentation ignored include_doc_comments")

test "runtime-equivalent routes follow first-reachable conflict policy":
  let parameter_conflict = app(openapi: { title: "Conflicts", version: "1" })
    .get("/items/:id", handler: duplicate_a_reply)
    .get("/items/:slug", handler: duplicate_b_reply)
  let parameter_rendered = openapi_string(parameter_conflict)
  require_contains(parameter_rendered, "\"/items/{id}\"".as_slice(), "first reachable parameter route was omitted")
  require_not_contains(parameter_rendered, "\"/items/{slug}\"".as_slice(), "unreachable parameter route was documented")
  require_not_contains(parameter_rendered, "\"right\"".as_slice(), "unreachable route leaked a schema component")

  let documented_conflict = parameter_conflict.with_route_docs(
    "/items/:slug",
    method: Method::Get {},
    docs: RouteDocs::empty().with_description("First runtime route documentation")
  )
  require_contains(
    openapi_string(documented_conflict),
    "First runtime route documentation".as_slice(),
    "route docs did not target the first runtime-equivalent route"
  )

  let slash_conflict = app(openapi: { title: "Slashes", version: "1" })
    .with(trailing_slash: ignore_trailing_slash())
    .get("/slash", handler: duplicate_a_reply)
    .get("/slash/", handler: duplicate_b_reply)
  let slash_rendered = openapi_string(slash_conflict)
  require_contains(slash_rendered, "\"/slash\"".as_slice(), "first slash route was omitted")
  require_not_contains(slash_rendered, "\"/slash/\"".as_slice(), "runtime-equivalent slash route was documented")
  require_not_contains(slash_rendered, "\"right\"".as_slice(), "slash conflict leaked a schema component")

  let documented_slash = slash_conflict.with_route_docs(
    "/slash/",
    method: Method::Get {},
    docs: RouteDocs::empty().with_description("Normalized slash documentation")
  )
  require_contains(
    openapi_string(documented_slash),
    "Normalized slash documentation".as_slice(),
    "route docs ignored normalized trailing-slash ownership"
  )

  let hidden_conflict = app(openapi: { title: "Hidden conflicts", version: "1" })
    .route<Json<DuplicateA>>(
      "/private/:id",
      method: Method::Get {},
      handler: (_ctx: Context) -> Json<DuplicateA> => duplicate_a_reply(),
      docs: { hidden: true }
    )
    .get("/private/:slug", handler: duplicate_b_reply)
  require_not_contains(
    openapi_string(hidden_conflict),
    "\"/private/".as_slice(),
    "visible metadata exposed a runtime route hidden by the first match"
  )

test "literal braces remain literal path text":
  let value = app(openapi: { title: "Literal paths", version: "1" })
    .get("/literal/{id}", handler: duplicate_a_reply)
  let rendered = openapi_string(value)
  require_contains(rendered, "\"/literal/%7Bid%7D\"".as_slice(), "literal braces were interpreted as a path parameter")
  require_not_contains(rendered, "\"name\":\"id\"".as_slice(), "literal braces fabricated a path parameter")

test "automatic request contracts cover parameters and limited body extractors":
  let base = app(openapi: { title: "Requests", version: "1" })
  let with_path = route_params<DocumentedArticlePath, Text>(
    base,
    "/articles/:id".as_slice(),
    method: Method::Get {},
    path_reply
  )
  let with_query = route_query_context<DocumentedArticleQuery, Text>(
    with_path,
    "/articles",
    method: Method::Get {},
    query_reply
  )
  let with_headers = route_headers<HeaderInput, Text>(
    with_query,
    "/headers",
    method: Method::Get {},
    header_reply
  )
  let with_cookies = route_cookies<CookieInput, Text>(
    with_headers,
    "/cookies",
    method: Method::Get {},
    cookie_reply
  )
  let with_json = with_cookies.post(
    "/limited-json",
    body: limited(json_body(), limit: body_limit(1024)),
    handler: limited_json_reply
  )
  let with_text = with_json.post(
    "/limited-text",
    body: limited(text_body(), limit: body_limit(1024)),
    handler: text_body_reply
  )
  let documented = with_text.post(
    "/limited-bytes",
    body: limited(bytes(), limit: body_limit(1024)),
    handler: bytes_body_reply
  )
  match(stringify(documented.openapi()))
    Err:
      Test::fail()
    Ok<String> { value }:
      require_contains(value, "\"/articles/{id}\"".as_slice(), "path was not normalized")
      require_contains(value, "\"in\":\"path\"".as_slice(), "missing path parameter")
      require_contains(value, "\"in\":\"query\"".as_slice(), "missing query parameter")
      require_contains(value, "\"in\":\"header\"".as_slice(), "missing header parameter")
      require_contains(value, "\"in\":\"cookie\"".as_slice(), "missing cookie parameter")
      require_contains(value, "\"application/json\"".as_slice(), "missing limited JSON contract")
      require_contains(value, "\"text/plain\"".as_slice(), "missing limited text contract")
      require_contains(value, "\"application/octet-stream\"".as_slice(), "missing limited bytes contract")
      require_contains(value, "JSON accepted by POST /automatic/articles.".as_slice(), "limited JSON lost its DTO schema")

test "raw JSON inputs remain opaque":
  let raw_json_app = app(openapi: { title: "Raw JSON", version: "1" })
    .post("/raw-json", body: json_body(), handler: raw_json_input_reply)
  let raw_json = openapi_string(raw_json_app)
  require_contains(raw_json, "\"application/json\"".as_slice(), "raw JSON media type was omitted")
  require_contains(raw_json, "\"default\"".as_slice(), "raw JSON response was fabricated")
  require_not_contains(raw_json, "\"schema\":".as_slice(), "raw JSON fabricated a schema")
  let response = raw_json_app.handle(IncomingRequest {
    method: Method::Post {},
    path: "/raw-json",
    query: None {},
    headers: Headers::empty().set(
      header: "content-type",
      value: "application/json"
    ),
    body: Body::text("{\"ok\":true}")
  })
  assert(response.status.code(), eq: 200)

test "raw typed-parameter responses remain opaque":
  let raw_params_app = app(openapi: { title: "Raw parameters", version: "1" })
    .get_params<DocumentedArticlePath>("/articles/:id", handler: raw_path_reply)
    .get_params_query<DocumentedArticlePath, DocumentedArticleQuery>(
      "/search/:id",
      handler: raw_path_query_reply
    )
  let raw_params = openapi_string(raw_params_app)
  require_contains(raw_params, "\"default\"".as_slice(), "raw parameter response was fabricated")
  require_not_contains(raw_params, "\"200\"".as_slice(), "raw parameter response fabricated status 200")

fn require_contains(value: String, needle: StringSlice, message: String) -> void
  if not value.contains(needle):
    panic(message)

fn require_not_contains(value: String, needle: StringSlice, message: String) -> void
  if value.contains(needle):
    panic(message)

fn openapi_string(value: App) -> String
  match(stringify(value.openapi()))
    Ok<String> { value }:
      value
    Err:
      "".to_string()

fn openapi_string(value: App, { include_doc_comments: bool }) -> String
  match(stringify(value.openapi(include_doc_comments: include_doc_comments)))
    Ok<String> { value }:
      value
    Err:
      "".to_string()
