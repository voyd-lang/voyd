    app(openapi: { title: "Cookies", version: "1" }),
    "/cookies",
    method: Method::Get {},
    cookie_reply
  )
  require_contains(openapi_string(value), "\"in\":\"cookie\"".as_slice(), "missing standalone cookie contract")

test "combined free extractors retain every parameter contract":
  let value = route_params_query_headers<DocumentedArticlePath, DocumentedArticleQuery, HeaderInput, Text>(
    app(openapi: { title: "Combined", version: "1" }),
    "/articles/:id",
    method: Method::Get {},
    combined_reply
  )
  let rendered = openapi_string(value)
  require_contains(rendered, "\"in\":\"path\"".as_slice(), "combined route lost path parameters")
  require_contains(rendered, "\"in\":\"query\"".as_slice(), "combined route lost query parameters")
  require_contains(rendered, "\"in\":\"header\"".as_slice(), "combined route lost header parameters")

test "app router and free route entry surfaces retain equivalent typed contracts":
  let direct = app(openapi: { title: "Surfaces", version: "1" })
    .post("/app", body: json_body(), handler: create_automatic_article)
    .put("/app-put", body: json_body(), handler: create_automatic_article)
    .patch(
      "/app-patch",
      body: limited(json_body(), limit: body_limit(2048)),
      limit: body_limit(4096),
      timeout: timeout_millis(50),
      handler: create_automatic_article
    )
    .get_params<DocumentedArticlePath, Text>("/app-path/:id", handler: path_reply)
    .get<String, Text>("/app-auth", auth: required_session(), handler: session_reply)
  let free = route(
    direct,
    "/free",
    method: Method::Post {},
    body: json_body(),
    create_automatic_article
  )
  let routed = Router::init()
    .post("/router", body: json_body(), handler: create_automatic_article)
    .delete("/router-delete", body: json_body(), handler: create_automatic_article)
    .get_params<DocumentedArticlePath, Text>("/router-path/:id", handler: path_reply)
    .get<String, Text>("/router-auth", auth: required_session(), handler: session_reply)
    .route<AutomaticCreateArticle, Created<AutomaticArticle>>(
      "/router-direct",
      method: Method::Post {},
      body: json_body(),
      limit: body_limit(4096),
      timeout: timeout_millis(50),
      handler: create_automatic_article,
      docs: { description: "Direct Router.route contract" }
    )
    .route<Text>(
      "/router-context",
      method: Method::Get {},
      timeout: timeout_millis(50),
      handler: context_text_reply
    )
  let rendered = openapi_string(free.mount("/mounted", routed))
  require_contains(rendered, "\"/app\"".as_slice(), "App route contract was omitted")
  require_contains(rendered, "\"/free\"".as_slice(), "free route contract was omitted")
  require_contains(rendered, "\"/mounted/router\"".as_slice(), "Router route contract was omitted")
  require_contains(rendered, "\"/app-path/{id}\"".as_slice(), "App typed path contract was omitted")
  require_contains(rendered, "\"/mounted/router-path/{id}\"".as_slice(), "Router typed path contract was omitted")
  require_contains(rendered, "\"/app-auth\"".as_slice(), "App auth route contract was omitted")
  require_contains(rendered, "\"/mounted/router-auth\"".as_slice(), "Router auth route contract was omitted")
  require_contains(rendered, "\"/app-put\"".as_slice(), "App PUT body contract was omitted")
  require_contains(rendered, "\"/app-patch\"".as_slice(), "App policy body contract was omitted")
  require_contains(rendered, "\"/mounted/router-delete\"".as_slice(), "Router DELETE body contract was omitted")
  require_contains(rendered, "\"/mounted/router-direct\"".as_slice(), "direct Router.route body contract was omitted")
  require_contains(rendered, "\"/mounted/router-context\"".as_slice(), "direct Router.route context contract was omitted")
  require_contains(rendered, "Direct Router.route contract".as_slice(), "direct Router.route metadata was omitted")
  require_contains(rendered, "\"in\":\"path\"".as_slice(), "typed path parameters differed by route surface")
  require_contains(rendered, "JSON accepted by POST /automatic/articles.".as_slice(), "JSON body schemas differed by route surface")
  require_contains(rendered, "\"201\"".as_slice(), "typed response contract differed by route surface")

test "limited JSON bodies preserve their request contract":
  let value = app(openapi: { title: "Bodies", version: "1" }).post(
    "/limited-json",
    body: limited(json_body(), limit: body_limit(1024)),
    handler: limited_json_reply
  )
  let rendered = openapi_string(value)
  require_contains(rendered, "\"application/json\"".as_slice(), "missing standalone limited JSON contract")
  require_contains(rendered, "JSON accepted by POST /automatic/articles.".as_slice(), "standalone limited JSON lost its DTO schema")

