use src::policy::timeout_millis


fn create_automatic_article(input: AutomaticCreateArticle) -> Created<AutomaticArticle>
  created(AutomaticArticle { id: 1, title: input.title })

obj HeaderInput {
  api authorization: String,
  api trace_id?: String
}

obj CookieInput {
  api session: String
}

fn path_reply(_params: DocumentedArticlePath) -> Text
  text("path")

fn context_text_reply(_ctx: Context) -> Text
  text("ok")

fn query_reply(_query: DocumentedArticleQuery, _ctx: Context) -> Text
  text("query")

fn header_reply(_headers: HeaderInput) -> Text
  text("header")

fn cookie_reply(_cookies: CookieInput) -> Text
  text("cookie")

fn combined_reply(
  _params: DocumentedArticlePath,
  _query: DocumentedArticleQuery,
  _headers: HeaderInput
) -> Text
  text("combined")

fn limited_json_reply(input: AutomaticCreateArticle) -> Created<AutomaticArticle>
  create_automatic_article(input)

fn text_body_reply(_input: String) -> Text
  text("text")

fn bytes_body_reply(_input: Bytes) -> Text
  text("bytes")

fn session_reply(_session: String) -> Text
  text("authenticated")

obj CustomTextBody {}

impl FromBody<String> for CustomTextBody
  fn extract_body(self, _request: IncomingRequest) : (open) -> Result<String, Rejection>
    self
    Ok<String> { value: "custom" }

  fn openapi_request(self) -> Option<OpenApiRequestContract>
    self
    Some<OpenApiRequestContract> { value: text_request() }

fn custom_body_reply(_input: String) -> Text
  text("custom")

fn multipart_reply(_input: Form) -> Text
  text("multipart")

fn raw_json_input_reply(_input: JsonValue) -> Response
  Response::ok().empty()

fn raw_path_reply(_params: DocumentedArticlePath) -> Response
  Response::ok().empty()

fn raw_path_query_reply(
  _params: DocumentedArticlePath,
  _query: DocumentedArticleQuery
) -> Response
  Response::ok().empty()

fn recursive_reply(_input: DocumentedRecursivePair) -> Response
  Response::no_content().empty()

fn duplicate_a_reply() -> Json<DuplicateA>
  json(DuplicateA { left: 1 })

fn duplicate_b_reply() -> Json<DuplicateB>
  json(DuplicateB { right: "two" })

fn generic_path_operation<P>() -> Operation
  operation().with_path_params<P>()

test "app-owned OpenAPI derives JSON request and created response contracts":
  let article_app = app(openapi: {
    title: "Articles API",
    version: "1.0.0",
    description: "Automatic API"
  }).post(
    "/automatic/articles",
    body: json_body(),
    handler: create_automatic_article,
    docs: {
      description: "Create an article",
      operation_id: "createArticle",
      tags: ["articles"]
    }
  ).expose_openapi(
    at: "/openapi.json",
    include_doc_comments: true
  )
  match(stringify(article_app.openapi()))
    Err:
      Test::fail()
    Ok<String> { value }:
      require_contains(value, "\"/automatic/articles\"".as_slice(), "missing automatic path")
      require_contains(value, "\"201\"".as_slice(), "missing created status")
      require_contains(value, "\"application/json\"".as_slice(), "missing JSON media type")
      require_contains(value, "Reader-visible article title.".as_slice(), "missing doc comments")

  match(stringify(article_app.openapi(include_doc_comments: false)))
    Err:
      Test::fail()
    Ok<String> { value }:
      assert(value.contains("Reader-visible article title.".as_slice()), eq: false)
      require_contains(value, "Create an article".as_slice(), "explicit docs were removed")

test "typed JSON routes infer responses without route metadata":
  let article_app = app(openapi: { title: "Articles API", version: "1.0.0" })
    .post("/articles", body: json_body(), handler: create_automatic_article)
  match(stringify(article_app.openapi()))
    Err:
      Test::fail()
    Ok<String> { value }:
      require_contains(value, "\"201\"".as_slice(), "missing inferred created status")
      require_contains(value, "\"application/json\"".as_slice(), "missing inferred JSON response")

test "explicit schema prose overlays inferred request and response types":
  let article_app = app(openapi: { title: "Articles API", version: "1.0.0" })
    .post(
      "/articles",
      body: json_body(),
      handler: create_automatic_article,
      docs: route_docs({
        request_schema: openapi_schema_docs(
          description: "Explicit request schema",
          fields: [openapi_field_docs(name: "title", description: "Explicit request title")]
        ),
        response_schemas: [openapi_response_schema_docs(
          status: 201,
          schema: openapi_schema_docs(
            description: "Explicit response schema",
            fields: [openapi_field_docs(name: "id", description: "Explicit response id")]
          )
        )]
      })
    )
  let rendered = openapi_string(article_app, include_doc_comments: false)
  assert(rendered.contains("Explicit request schema".as_slice()), eq: true)
  require_contains(rendered, "Explicit request title".as_slice(), "request field overlay was omitted")
  require_contains(rendered, "Explicit response schema".as_slice(), "response schema overlay was omitted")
  require_contains(rendered, "Explicit response id".as_slice(), "response field overlay was omitted")

test "schema prose overlays do not mutate shared inferred components":
  let article_app = app(openapi: { title: "Articles API", version: "1.0.0" })
    .post(
      "/overlaid",
      body: json_body(),
      handler: create_automatic_article,
      docs: route_docs({
        request_schema: openapi_schema_docs(description: "Route-only request prose"),
        response_schemas: [openapi_response_schema_docs(
          status: 201,
          schema: openapi_schema_docs(description: "Route-only response prose")
        )]
      })
    )
    .post("/plain", body: json_body(), handler: create_automatic_article)
  let rendered = openapi_string(article_app)
  require_contains(rendered, "Route-only request prose".as_slice(), "request overlay was omitted")
  require_contains(rendered, "Route-only response prose".as_slice(), "response overlay was omitted")
  require_contains(rendered, "JSON accepted by POST /automatic/articles.".as_slice(), "request overlay mutated the shared component")
  require_contains(rendered, "JSON returned after an article is created.".as_slice(), "response overlay mutated the shared component")

test "automatic OpenAPI hides routes and is deterministic":
  let hidden_app = app(openapi: { title: "Hidden", version: "1" })
    .post(
      "/visible",
      body: json_body(),
      handler: create_automatic_article,
      docs: { operation_id: "visible", hidden: false }
    )
    .post(
      "/hidden",
      body: json_body(),
      handler: create_automatic_article,
      docs: { hidden: true }
    )
  match(stringify(hidden_app.openapi()))
    Err:
      Test::fail()
    Ok<String> { value: first }:
      assert(first.contains("\"/hidden\"".as_slice()), eq: false)
      match(stringify(hidden_app.openapi()))
        Ok<String> { value: second }:
          assert(first, eq: second)
        Err:
          Test::fail()

test "explicit path parameters remain required":
  let documented = app(openapi: { title: "Paths", version: "1" })
    .route<Text>(
      "/articles/:id",
      method: Method::Get {},
      handler: (_ctx: Context) -> Text => text("ok"),
      docs: route_docs(parameters: [
        openapi_parameter<String>(
          name: "id",
          location: "path",
          required: false
        )
      ])
    )
  let rendered = openapi_string(documented)
  require_contains(rendered, "\"/articles/{id}\"".as_slice(), "path override removed its route")
  require_contains(rendered, "\"required\":true".as_slice(), "path override was not required")

test "raw context routes document placeholders as required opaque path parameters":
  let documented = app(openapi: { title: "Paths", version: "1" })
    .get("/raw/:id", handler: (_ctx: Context) -> Response => Response::ok().empty())
  let rendered = openapi_string(documented)
  require_contains(rendered, "\"/raw/{id}\"".as_slice(), "raw path was not normalized")
  require_contains(rendered, "\"name\":\"id\"".as_slice(), "raw placeholder name was omitted")
  require_contains(rendered, "\"in\":\"path\"".as_slice(), "raw placeholder location was omitted")
  require_contains(rendered, "\"required\":true".as_slice(), "raw placeholder was not required")
  require_contains(rendered, "\"schema\":{\"type\":\"string\"}".as_slice(), "raw placeholder omitted its honest string schema")

test "generic operation helpers preserve reified shapes":
  let generic_spec = document(info(title: "Generic", version: "1"))
    .route("/generic/:id", method: Method::Get {}, operation: generic_path_operation<DocumentedArticlePath>())
  match(stringify(generic_spec.json()))
    Err:
      Test::fail()
    Ok<String> { value }:
      require_contains(value, "\"/generic/{id}\"".as_slice(), "generic shape was not preserved")

test "free query routes preserve contracts":
  let value = route_query_context<DocumentedArticleQuery, Text>(
    app(openapi: { title: "Query", version: "1" }),
    "/query",
    method: Method::Get {},
    query_reply
  )
  require_contains(openapi_string(value), "\"in\":\"query\"".as_slice(), "missing standalone query contract")

test "route-local docs can be attached to specialized route surfaces":
  let value = route_query_context<DocumentedArticleQuery, Text>(
    app(openapi: { title: "Query", version: "1" }),
    "/query",
    method: Method::Get {},
    query_reply
  ).with_route_docs(
    "/query",
    method: Method::Get {},
    docs: RouteDocs::empty().with_description("Specialized query route")
  )
  require_contains(openapi_string(value), "Specialized query route".as_slice(), "specialized route docs were omitted")

test "advanced route docs preserve existing inline metadata":
  let value = app(openapi: { title: "Layered docs", version: "1" })
    .route<Text>(
      "/layered",
      method: Method::Get {},
      handler: context_text_reply,
      docs: {
        summary: "Inline summary",
        description: "Inline description",
        operation_id: "layeredOperation",
        tags: ["layered"]
      }
    )
    .with_route_docs(
      "/layered",
      method: Method::Get {},
      docs: route_docs(responses: [
        openapi_json_response<AutomaticArticle>(status: 200, description: "Layered response")
      ])
    )
  let rendered = openapi_string(value)
  require_contains(rendered, "Inline summary".as_slice(), "advanced docs removed an inline summary")
  require_contains(rendered, "Inline description".as_slice(), "advanced docs removed an inline description")
  require_contains(rendered, "layeredOperation".as_slice(), "advanced docs removed an inline operation ID")
  require_contains(rendered, "\"layered\"".as_slice(), "advanced docs removed inline tags")
  require_contains(rendered, "Layered response".as_slice(), "advanced response docs were omitted")

test "rejected routes do not reserve operation IDs":
  let value = app(openapi: { title: "Operation IDs", version: "1" })
    .route<Text>(
      "/invalid",
      method: Method::Get {},
      handler: (_ctx: Context) -> Text => text("invalid"),
      docs: route_docs({
        operation_id: "sharedOperation",
        parameters: [openapi_parameter<String>(name: "id", location: "path")]
      })
    )
    .route<Text>(
      "/valid",
      method: Method::Get {},
      handler: context_text_reply,
      docs: { operation_id: "sharedOperation" }
    )
  let rendered = openapi_string(value)
  assert(rendered.contains("\"/invalid\"".as_slice()), eq: false)
  require_contains(rendered, "\"/valid\"".as_slice(), "valid route was omitted")
  require_contains(rendered, "\"operationId\":\"sharedOperation\"".as_slice(), "rejected route consumed a valid operation ID")

