use src::openapi::{ document, info, operation, operation_with_request }
use src::contract::{ OpenApiHeader, OpenApiParameterContract, OpenApiResponseContract, RouteDocs, openapi_header, openapi_json_response, openapi_opaque_request, openapi_untyped_header, route_docs }
use src::contract::openapi_response as response_override
use src::phase3_openapi_types::{
  DocumentedArticle,
  DocumentedArticlePath,
  DocumentedArticleQuery,
  DocumentedCreateArticle,
  DocumentedEvent,
  DocumentedRecursivePair,
  AutomaticArticle,
  AutomaticCreateArticle
}
use std::array::Array
use std::bytes::{ ByteBuffer, Bytes }
use std::http::{ Method, Response }
use std::http::server::self as server
use std::json::stringify
use std::error::panic
use std::optional::types::all
use std::result::types::all
use std::string::type::{ String, StringSlice }
use std::test::assertions::all
use src::extract::json_body
use src::response::{ Accepted, Created, DocumentedResponse, IntoResponse, Json, NoContent, OpenApiResponse, Text, accepted, bytes, created, documented_response, json, no_content, option_json, result_json, text }
use src::response_docs::{ inferred_responses, option_responses, result_responses }
use src::response_composites::self as response_composites
use src::router::{ App, Context, app }
use src::automatic_openapi::all
use src::html::{ HtmlResponse, html }
use src::sse::{ Sender, SseResponse }
use src::sse::typed_response as sse_response


obj CustomReply {
  api message: String
}

obj UndocumentedReply {
  api message: String
}

impl IntoResponse<UndocumentedReply> for UndocumentedReply
  fn into_response(self) -> Response
    Response::ok().text(self.message)

impl IntoResponse<CustomReply> for CustomReply
  fn into_response(self) -> Response
    Response::ok().text(self.message)

impl OpenApiResponse<CustomReply> for CustomReply
  fn documented_responses() -> Array<OpenApiResponseContract>
    [openapi_json_response<AutomaticArticle>(status: 203, description: "Custom response")]

fn raw_reply(_input: AutomaticCreateArticle): (open) -> Response
  Response::ok().text("raw")

fn custom_reply() -> DocumentedResponse<CustomReply>
  documented_response(CustomReply { message: "custom" })

fn raw_unit_reply() -> Response
  Response::ok().text("raw")

fn text_reply() -> String
  "plain".to_string()

fn binary_reply() -> Bytes
  let ~buffer = ByteBuffer::init()
  buffer.push(98)
  buffer.push(121)
  buffer.push(116)
  buffer.push(101)
  buffer.push(115)
  buffer.as_bytes()

fn accepted_reply() -> Accepted<AutomaticArticle>
  accepted(AutomaticArticle { id: 2, title: "queued".to_string() })

fn empty_reply() -> NoContent
  no_content()

fn result_reply() -> Result<Created<AutomaticArticle>, Accepted<AutomaticArticle>>
  Ok<Created<AutomaticArticle>> {
    value: created(AutomaticArticle { id: 3, title: "created".to_string() })
  }

fn option_reply() -> Option<Json<AutomaticArticle>>
  Some<Json<AutomaticArticle>> {
    value: json(AutomaticArticle { id: 4, title: "found".to_string() })
  }

fn mapped_result_reply() -> Result<Json<AutomaticArticle>, Accepted<AutomaticArticle>>
  let value: Result<AutomaticArticle, Accepted<AutomaticArticle>> = Ok<AutomaticArticle> {
    value: AutomaticArticle { id: 5, title: "mapped" }
  }
  result_json<AutomaticArticle, Accepted<AutomaticArticle>>(value)

fn mapped_option_reply() -> Option<Json<AutomaticArticle>>
  option_json<AutomaticArticle>(Some<AutomaticArticle> {
    value: AutomaticArticle { id: 6, title: "optional" }
  })

fn html_reply() -> HtmlResponse
  html("<main>ready</main>")

fn write_sse(_sender: Sender): server::ResponseWriter -> void
  void

fn sse_reply(): (server::ResponseStream, open) -> SseResponse
  sse_response(write_sse)

fn accepts_response<T: IntoResponse<T>>(value: T) -> T
  value

test "typed response contracts cover statuses text result and option":
  let spec = document(info(title: "Responses", version: "1"))
    .route("/created", method: Method::Get {}, operation: operation().with_responses(inferred_responses<Created<AutomaticArticle>>()))
    .route("/accepted", method: Method::Get {}, operation: operation().with_responses(inferred_responses<Accepted<AutomaticArticle>>()))
    .route("/empty", method: Method::Get {}, operation: operation().with_responses(inferred_responses<NoContent>()))
    .route("/text", method: Method::Get {}, operation: operation().with_responses(inferred_responses<Text>()))
    .route("/result", method: Method::Get {}, operation: operation().with_responses(result_responses<Created<AutomaticArticle>, Accepted<AutomaticArticle>>() ))
    .route("/option", method: Method::Get {}, operation: operation().with_responses(option_responses<Json<AutomaticArticle>>() ))
  match(stringify(spec.json()))
    Err:
      Test::fail()
    Ok<String> { value }:
      require_contains(value, "\"201\"".as_slice(), "missing created response")
      require_contains(value, "\"202\"".as_slice(), "missing accepted response")
      require_contains(value, "\"204\"".as_slice(), "missing no-content response")
      require_contains(value, "\"404\"".as_slice(), "missing option not-found response")
      require_contains(value, "\"text/plain; charset=utf-8\"".as_slice(), "missing text response")

test "opaque branches remain visible in result and option contracts":
  let spec = document(info(title: "Opaque composites", version: "1"))
    .route(
      "/result",
      method: Method::Get {},
      operation: operation().with_responses(
        inferred_responses<Result<Created<AutomaticArticle>, UndocumentedReply>>()
      )
    )
    .route(
      "/option",
      method: Method::Get {},
      operation: operation().with_responses(
        inferred_responses<Option<UndocumentedReply>>()
      )
    )
  match(stringify(spec.json()))
    Err:
      Test::fail()
    Ok<String> { value }:
      require_contains(value, "\"201\"".as_slice(), "typed result branch was omitted")
      require_contains(value, "\"404\"".as_slice(), "option fallback was omitted")
      require_contains(value, "\"default\"".as_slice(), "opaque composite branch was fabricated or dropped")

test "request overrides and same-status response media types are preserved":
  let request = openapi_opaque_request(
    content_type: "application/json",
    description: "Optional input".to_string(),
    required: false
  )
  let spec = document(info(title: "Overrides", version: "1"))
    .route(
      "/merge",
      method: Method::Post {},
      operation: operation_with_request(operation(), request)
        .with_responses([
          openapi_json_response<AutomaticArticle>(
            status: 200,
            description: "JSON",
            headers: [openapi_header<i32>(
              name: "x-rate-limit",
              description: "Remaining requests".to_string(),
              required: true
            )]
          ),
          response_override(
            status: 200,
            description: "Text".to_string(),
            content_type: Some<String> { value: "text/plain".to_string() }
          )
        ])
    )
  match(stringify(spec.json()))
    Err:
      Test::fail()
    Ok<String> { value }:
      require_contains(value, "Optional input".as_slice(), "missing request description")
      require_contains(value, "\"required\":false".as_slice(), "missing optional request body")
      require_contains(value, "\"application/json\"".as_slice(), "missing JSON response alternative")
      require_contains(value, "\"text/plain\"".as_slice(), "missing text response alternative")
      require_contains(value, "x-rate-limit".as_slice(), "missing response header")
      require_contains(value, "\"required\":true".as_slice(), "required response header became optional")

test "untyped parameter and response header overrides emit honest schemas":
  let parameter = OpenApiParameterContract {
    name: "trace".to_string(),
    location: "query".to_string(),
    description: None {},
    schema: None {},
    required: false
  }
  let header = openapi_untyped_header(name: "x-dynamic")
  let response = openapi_json_response<AutomaticArticle>(
    status: 200,
    description: "Dynamic response",
    headers: [header]
  )
  let parameter_docs = RouteDocs::empty().with_parameters([parameter])
  let docs = parameter_docs.with_responses([response])
  let documented = app(openapi: { title: "Opaque overrides", version: "1" })
    .route<Response>(
      "/opaque-overrides",
      method: Method::Get {},
      handler: (_ctx: Context) -> Response => Response::ok().empty(),
      docs: docs
    )
  match(stringify(documented.openapi()))
    Err:
      Test::fail()
    Ok<String> { value }:
      require_contains(value, "\"name\":\"trace\"".as_slice(), "untyped parameter was omitted")
      require_contains(value, "\"x-dynamic\"".as_slice(), "untyped response header was omitted")
      require_contains(value, "\"schema\":{}".as_slice(), "untyped parameter omitted its honest empty schema")
      require_contains(value, "\"type\":\"string\"".as_slice(), "untyped response header omitted its wire string schema")

test "raw and custom responses use explicit response documentation":
  let custom_spec = document(info(title: "Custom", version: "1"))
    .route("/custom", method: Method::Get {}, operation: operation().with_responses(CustomReply::documented_responses()))
    .route("/raw-override", method: Method::Get {}, operation: operation().with_responses([
      openapi_json_response<AutomaticArticle>(status: 206, description: "Partial article")
    ]))
  let documented = app(openapi: { title: "Overrides", version: "1" })
    .post(
      "/raw".as_slice(),
      body: json_body(),
      handler: raw_reply,
      docs: route_docs(responses: [
        openapi_json_response<AutomaticArticle>(status: 206, description: "Partial article")
      ])
    )
  match(stringify(custom_spec.json()))
    Err:
      Test::fail()
    Ok<String> { value }:
      require_contains(value, "\"203\"".as_slice(), "missing custom response contract")
      require_contains(value, "\"206\"".as_slice(), "missing response override")
  match(stringify(documented.openapi()))
    Err:
      Test::fail()
    Ok<String> { value }:
      require_contains(value, "\"/raw\"".as_slice(), "missing raw response route")
      require_contains(value, "\"206\"".as_slice(), "missing raw response override")

test "automatic routes cover typed custom text binary result option and opaque responses":
  let _ = accepts_response<Result<Created<AutomaticArticle>, Accepted<AutomaticArticle>>>(result_reply())
  let with_custom = app(openapi: { title: "Responses", version: "1" })
    .get<DocumentedResponse<CustomReply>>("/custom", handler: custom_reply)
  let with_raw = with_custom.get("/raw", handler: raw_unit_reply)
  let with_text = with_raw.get("/text", handler: text_reply)
  let with_binary = with_text.get("/binary", handler: binary_reply)
  let with_accepted = with_binary.get("/accepted", handler: accepted_reply)
  let with_empty = with_accepted.get("/empty", handler: empty_reply)
  let with_result = with_empty.get<Result<Created<AutomaticArticle>, Accepted<AutomaticArticle>>>("/result", handler: result_reply)
  let with_option = with_result.get<Option<Json<AutomaticArticle>>>("/option", handler: option_reply)
  let with_html = with_option.get("/html", handler: html_reply)
  let web_app = with_html.get<SseResponse>("/events", handler: sse_reply)
  match(stringify(web_app.openapi()))
    Err:
      Test::fail()
    Ok<String> { value }:
      require_contains(value, "\"203\"".as_slice(), "missing custom automatic response")
      require_contains(value, "\"202\"".as_slice(), "missing accepted automatic response")
      require_contains(value, "\"204\"".as_slice(), "missing no-content automatic response")
      require_contains(value, "\"201\"".as_slice(), "missing result success response")
      require_contains(value, "\"404\"".as_slice(), "missing option not-found response")
      require_contains(value, "\"text/plain; charset=utf-8\"".as_slice(), "missing automatic text response")
      require_contains(value, "\"application/octet-stream\"".as_slice(), "missing automatic binary response")
      require_contains(value, "\"text/html; charset=utf-8\"".as_slice(), "missing automatic HTML response")
      require_contains(value, "\"text/event-stream; charset=utf-8\"".as_slice(), "SSE media type omitted its charset")
      require_contains(value, "\"x-voyd-event-schema\"".as_slice(), "SSE event schema metadata was omitted")
      require_contains(value, "Opaque response".as_slice(), "raw response was not kept opaque")

test "JSON result and option helpers preserve automatic response contracts":
  let web_app = app(openapi: { title: "Mapped responses", version: "1" })
    .get<Result<Json<AutomaticArticle>, Accepted<AutomaticArticle>>>(
      "/result-json",
      handler: mapped_result_reply
    )
    .get<Option<Json<AutomaticArticle>>>(
      "/option-json",
      handler: mapped_option_reply
    )
  match(stringify(web_app.openapi()))
    Err:
      Test::fail()
    Ok<String> { value }:
      require_contains(value, "\"200\"".as_slice(), "mapped JSON success was erased")
      require_contains(value, "\"202\"".as_slice(), "mapped result error was erased")
      require_contains(value, "\"404\"".as_slice(), "mapped option fallback was erased")
      require_contains(value, "\"id\"".as_slice(), "mapped JSON DTO schema was erased")
      require_contains(value, "\"title\"".as_slice(), "mapped JSON DTO fields were erased")

test "same-status response branches preserve both schemas":
  let spec = document(info(title: "Alternatives", version: "1"))
    .route(
      "/alternative",
      method: Method::Get {},
      operation: operation().with_responses(
        result_responses<Json<AutomaticArticle>, Json<DocumentedArticle>>()
      )
    )
  match(stringify(spec.json()))
    Err:
      Test::fail()
    Ok<String> { value }:
      require_contains(value, "\"anyOf\"".as_slice(), "same-status response schemas were not preserved as alternatives")
      require_contains(value, "JSON returned after an article is created.".as_slice(), "first response schema was erased")
      require_contains(value, "Article returned by the API.".as_slice(), "second response schema was erased")

fn require_contains(value: String, needle: StringSlice, message: String) -> void
  if not value.contains(needle):
    panic(message)
