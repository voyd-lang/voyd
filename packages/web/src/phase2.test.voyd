}
use std::http::{ Body, Headers, IncomingRequest, Method, QueryString, Response }
use std::msgpack::MsgPack
use std::optional::types::all
use std::result::types::all
use std::string::type::String
use std::test::assertions::all
use std::vx::all

type TestProfile = {
  name: String,
  active: bool
}

type TestCookies = {
  session: String,
  theme: String
}

type SearchQuery = {
  q: String
}

type RequiredSearchQuery = {
  page: i32,
  verbose: bool
}

type IdParams = {
  id: String
}

fn request_with_body(method: Method, path: String, body: Body) -> IncomingRequest
  IncomingRequest {
    method: method,
    path: path,
    query: None {},
    headers: Headers::empty(),
    body: body
  }

fn request_with_headers(method: Method, path: String, headers: Headers) -> IncomingRequest
  IncomingRequest {
    method: method,
    path: path,
    query: None {},
    headers: headers,
    body: Body::empty()
  }

fn request_with_headers_and_body(method: Method, path: String, headers: Headers, body: Body) -> IncomingRequest
  IncomingRequest {
    method: method,
    path: path,
    query: None {},
    headers: headers,
    body: body
  }

fn response_text(response: Response) -> String
  match(response.text())
    Ok<String> { value }:
      value
    Err:
      "error".as_slice().to_string()

test "limited body policies reject oversized requests before extraction":
  let web_app = app()
    .post(
      "/limited".as_slice(),
      body: limit_body(text_body_policy(), limit: body_limit(4)),
      handler: (input: String) -> Response =>
        Response::ok().text(input)
    )

  let accepted = web_app.handle(
    request_with_body(
      Method::Post {},
      "/limited".as_slice().to_string(),
      Body::text("four".as_slice())
    )
  )
  assert(response_text(accepted).equals("four"), eq: true)

  let rejected = web_app.handle(
    request_with_body(
      Method::Post {},
      "/limited".as_slice().to_string(),
      Body::text("too long".as_slice())
    )
  )
  assert(rejected.status.code(), eq: 413)
  assert(response_text(rejected).equals("request body exceeds configured limit"), eq: true)

test "route body limit label rejects oversized requests":
  let web_app = post(
    app(),
    "/limited-label".as_slice(),
    body: text_body_policy(),
    limit: body_limit(4)
  ) do(input: String):
    Response::ok().text(input)

  let rejected = web_app.handle(
    request_with_body(
      Method::Post {},
      "/limited-label".as_slice().to_string(),
      Body::text("too long".as_slice())
    )
  )
  assert(rejected.status.code(), eq: 413)

test "structural query extraction rejects missing and invalid fields":
  match(extract_query<RequiredSearchQuery>(parse_query("verbose=true".as_slice())))
    Ok<RequiredSearchQuery>:
      assert(false, eq: true)
    Err<Rejection> { error }:
      assert(error.status.code(), eq: 400)
      assert(error.message.contains("page".as_slice()), eq: true)

  match(extract_query<RequiredSearchQuery>(parse_query("page=abc&verbose=true".as_slice())))
    Ok<RequiredSearchQuery>:
      assert(false, eq: true)
    Err<Rejection> { error }:
      assert(error.status.code(), eq: 400)
      assert(error.message.contains("page".as_slice()), eq: true)

test "route body dto helper converts handler DTO returns":
  let web_app = route_body_dto(
    app(),
    "/body-dto".as_slice(),
    method: Method::Post {},
    body: text_body_policy()
  ) do(input: String):
    let active = input.equals("on".as_slice().to_string())
    let profile: TestProfile = { name: "Body".as_slice().to_string(), active: active }
    profile

  let response = web_app.handle(
    request_with_body(
      Method::Post {},
      "/body-dto".as_slice().to_string(),
      Body::text("on".as_slice())
    )
  )
  assert(response_text(response).contains("\"active\":true".as_slice()), eq: true)

test "response helpers convert boundary DTOs to json":
  let profile: TestProfile = { name: "Ada".as_slice().to_string(), active: true }
  let json_response = json_dto<TestProfile>(profile)
  assert(json_response.status.code(), eq: 200)
  match(json_response.header("content-type".as_slice()))
    Some<String> { value }:
      assert(value.equals("application/json"), eq: true)
    None:
      assert(false, eq: true)
  let text = response_text(json_response)
  assert(text.contains("\"name\":\"Ada\"".as_slice()), eq: true)
  assert(text.contains("\"active\":true".as_slice()), eq: true)

  let created = response_dto_json(
    Response::created(),
    value: { name: "Grace".as_slice().to_string(), active: false }
  )
  assert(created.status.code(), eq: 201)
  assert(response_text(created).contains("\"active\":false".as_slice()), eq: true)

test "route dto helpers convert handler DTO returns to json":
  let web_app = route_context_dto(
    app(),
    "/profile".as_slice(),
    method: Method::Get {}
  ) do(_ctx: Context):
    let profile: TestProfile = { name: "Ada".as_slice().to_string(), active: true }
    profile

  let response = web_app.handle(
    request_with_headers(Method::Get {}, "/profile".as_slice().to_string(), Headers::empty())
  )
  assert(response.status.code(), eq: 200)
  assert(response_text(response).contains("\"name\":\"Ada\"".as_slice()), eq: true)

test "route result dto helpers convert successful DTO values":
  let context_app = route_context_result_dto(
    app(),
    "/profile-result".as_slice(),
    method: Method::Get {}
  ) do(_ctx: Context):
    let profile: TestProfile = { name: "Ada".as_slice().to_string(), active: true }
    let value: Result<TestProfile, Response> = Ok<TestProfile> { value: profile }
    value

  let context_response = context_app.handle(
    request_with_headers(Method::Get {}, "/profile-result".as_slice().to_string(), Headers::empty())
  )
  assert(response_text(context_response).contains("\"name\":\"Ada\"".as_slice()), eq: true)

  let query_app = route_query_context_result_dto(
    app(),
    "/query-result".as_slice(),
    method: Method::Get {}
  ) do(query: SearchQuery, _ctx: Context):
    let profile: TestProfile = { name: query.q, active: true }
    let value: Result<TestProfile, Response> = Ok<TestProfile> { value: profile }
    value

  let query_response = query_app.handle(
    IncomingRequest {
      method: Method::Get {},
      path: "/query-result".as_slice().to_string(),
      query: Some<QueryString> { value: QueryString { raw: "q=Grace".as_slice().to_string() } },
      headers: Headers::empty(),
      body: Body::empty()
    }
  )
  assert(response_text(query_response).contains("\"name\":\"Grace\"".as_slice()), eq: true)

test "params query result dto helpers convert successful DTO values":
  let web_app = route_params_query_context_result_dto(
    app(),
    "/profiles/:id".as_slice(),
    method: Method::Get {}
  ) do(params: IdParams, query: SearchQuery, _ctx: Context):
    let name = params.id.concat(":".as_slice()).concat(query.q)
    let profile: TestProfile = { name: name, active: true }
    let value: Result<TestProfile, Response> = Ok<TestProfile> { value: profile }
    value

  let response = web_app.handle(
    IncomingRequest {
      method: Method::Get {},
      path: "/profiles/ada".as_slice().to_string(),
      query: Some<QueryString> { value: QueryString { raw: "q=grace".as_slice().to_string() } },
      headers: Headers::empty(),
      body: Body::empty()
    }
  )
  assert(response_text(response).contains("\"name\":\"ada:grace\"".as_slice()), eq: true)

test "cookie route helpers decode typed cookie DTOs":
  let web_app = route_cookies_context(
    app(),
    "/cookies".as_slice(),
    method: Method::Get {}
  ) do(cookies: TestCookies, ctx: Context):
    let raw = ctx.cookie("session".as_slice()) ?? "missing".as_slice().to_string()
    cookies.session.concat(":".as_slice()).concat(cookies.theme).concat(":".as_slice()).concat(raw)

  let response = web_app.handle(
    request_with_headers(
      Method::Get {},
      "/cookies".as_slice().to_string(),
      Headers::empty().append(header: "cookie".as_slice(), value: "session=abc; theme=dark".as_slice())
    )
  )
  assert(response_text(response).equals("abc:dark:abc"), eq: true)

test "cookie route dto helpers convert handler DTO returns":
  let web_app = route_cookies_context_dto(
    app(),
    "/cookie-profile".as_slice(),
    method: Method::Get {}
  ) do(cookies: TestCookies, _ctx: Context):
    let profile: TestProfile = { name: cookies.session, active: cookies.theme.equals("dark".as_slice().to_string()) }
    profile

  let response = web_app.handle(
    request_with_headers(
      Method::Get {},
      "/cookie-profile".as_slice().to_string(),
      Headers::empty().append(header: "cookie".as_slice(), value: "session=ada; theme=dark".as_slice())
    )
  )
  assert(response_text(response).contains("\"name\":\"ada\"".as_slice()), eq: true)
  assert(response_text(response).contains("\"active\":true".as_slice()), eq: true)

test "cookie route result dto helpers convert successful DTO values":
  let web_app = route_cookies_context_result_dto(
