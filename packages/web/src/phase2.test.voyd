test "authenticated post body limit label rejects oversized requests":
  let web_app = post(
    app(),
    "/auth-limited".as_slice(),
    body: text_body_policy(),
    auth: required_session(),
    limit: body_limit(4)
  ) do(input: String, session: String):
    Response::ok().text(session.concat(":".as_slice()).concat(input))

  let rejected = web_app.handle(
    request_with_headers_and_body(
      Method::Post {},
      "/auth-limited".as_slice().to_string(),
      Headers::empty().append(header: "authorization".as_slice(), value: "ada".as_slice()),
      Body::text("too long".as_slice())
    )
  )
  assert(rejected.status.code(), eq: 413)

test "route context timeout policy composes with route helpers":
  let web_app = route_context(
    app(),
    "/slow".as_slice(),
    method: Method::Get {},
    timeout: timeout_millis(5)
  ) do(_ctx: Context):
    Response::ok().text("slow".as_slice())

  web_app
  assert(true, eq: true)

test "post timeout policy composes with body route helpers":
  let web_app = post(
    app(),
    "/slow-post".as_slice(),
    body: text_body_policy(),
    timeout: timeout_millis(5)
  ) do(input: String):
    Response::ok().text(input)

  web_app
  assert(true, eq: true)

test "authenticated post timeout policy composes with body auth route helpers":
  let web_app = post(
    app(),
    "/auth-slow-post".as_slice(),
    body: text_body_policy(),
    auth: required_session(),
    timeout: timeout_millis(5)
  ) do(input: String, session: String):
    Response::ok().text(session.concat(":".as_slice()).concat(input))

  web_app
  assert(true, eq: true)

test "policy route helpers compose with final context handlers":
  let body_limit_app = post(
    app(),
    "/body-context-limit".as_slice(),
    body: text_body_policy(),
    limit: body_limit(8)
  ) do(input: String, ctx: Context):
    Response::ok().text(ctx.request.path.concat(":".as_slice()).concat(input))
  body_limit_app

  let body_timeout_app = post(
    app(),
    "/body-context-timeout".as_slice(),
    body: text_body_policy(),
    timeout: timeout_millis(5)
  ) do(input: String, ctx: Context):
    Response::ok().text(ctx.request.path.concat(":".as_slice()).concat(input))
  body_timeout_app

  let required_limit_app = post(
    app(),
    "/auth-context-limit".as_slice(),
    body: text_body_policy(),
    auth: required_session(),
    limit: body_limit(8)
  ) do(input: String, session: String, ctx: Context):
    Response::ok().text(ctx.request.path.concat(":".as_slice()).concat(session).concat(input))
  required_limit_app

  let required_timeout_app = post(
    app(),
    "/auth-context-timeout".as_slice(),
    body: text_body_policy(),
    auth: required_session(),
    timeout: timeout_millis(5)
  ) do(input: String, session: String, ctx: Context):
    Response::ok().text(ctx.request.path.concat(":".as_slice()).concat(session).concat(input))
  required_timeout_app

  assert(true, eq: true)

test "named method route wrappers expose body and timeout policies":
  let get_auth_timeout_app = get(
    app(),
    "/auth-timeout".as_slice(),
    auth: required_session(),
    timeout: timeout_millis(5)
  ) do(session: String):
    Response::ok().text(session)
  get_auth_timeout_app

  let put_limit_app = put(
    app(),
    "/put-limit".as_slice(),
    body: text_body_policy(),
    limit: body_limit(8)
  ) do(input: String):
    Response::ok().text(input)
  put_limit_app

  let put_timeout_app = put(
    app(),
    "/put-timeout".as_slice(),
    body: text_body_policy(),
    timeout: timeout_millis(5)
  ) do(input: String, ctx: Context):
    Response::ok().text(ctx.request.path.concat(":".as_slice()).concat(input))
  put_timeout_app

  let patch_timeout_app = patch(
    app(),
    "/patch-timeout".as_slice(),
    body: text_body_policy(),
    auth: required_session(),
    timeout: timeout_millis(5)
  ) do(input: String, session: String, ctx: Context):
    Response::ok().text(ctx.request.path.concat(":".as_slice()).concat(session).concat(input))
  patch_timeout_app

  let delete_limit_app = delete(
    app(),
    "/delete-limit".as_slice(),
    body: text_body_policy(),
    auth: required_session(),
    limit: body_limit(8)
  ) do(input: String, session: String):
    Response::ok().text(session.concat(input))
  delete_limit_app

  assert(true, eq: true)

test "body routes compose limit and timeout policies":
  let post_app = post(
    app(),
    "/upload".as_slice(),
    body: text_body_policy(),
    limit: body_limit(128),
    timeout: timeout_millis(5)
  ) do(input: String):
    Response::ok().text(input)
  post_app

  let route_app = route(
    app(),
    "/manual-upload".as_slice(),
    method: Method::Post {},
    body: text_body_policy(),
    limit: body_limit(128),
    timeout: timeout_millis(5)
  ) do(input: String, ctx: Context):
    Response::ok().text(ctx.request.path.concat(":".as_slice()).concat(input))
  route_app

  let auth_app = post(
    app(),
    "/auth-upload".as_slice(),
    body: text_body_policy(),
    auth: required_session(),
    limit: body_limit(128),
    timeout: timeout_millis(5)
  ) do(input: String, session: String):
    Response::ok().text(session.concat(":".as_slice()).concat(input))
  auth_app

  assert(true, eq: true)

test "cookie routes do not require final context":
  let web_app = route_cookies(
    app(),
    "/cookie-only".as_slice(),
    method: Method::Get {}
  ) do(cookies: TestCookies):
    Response::ok().text(cookies.session.concat(":".as_slice()).concat(cookies.theme))

  let response = web_app.handle(
    request_with_headers(
      Method::Get {},
      "/cookie-only".as_slice().to_string(),
      Headers::empty().append(header: "cookie".as_slice(), value: "session=ada; theme=dark".as_slice())
    )
  )
  assert(response_text(response).equals("ada:dark"), eq: true)

test "dto helpers cover params auth and body auth routes":
  let params_app = route_params_dto(
    app(),
    "/profile/:id".as_slice(),
    method: Method::Get {}
  ) do(params: IdParams):
    let profile: TestProfile = { name: params.id, active: true }
    profile
  params_app

  let params_result_app = route_params_result_dto(
    app(),
    "/profile-result/:id".as_slice(),
    method: Method::Get {}
  ) do(params: IdParams):
    let profile: TestProfile = { name: params.id, active: true }
    let value: Result<TestProfile, Response> = Ok<TestProfile> { value: profile }
    value
  params_result_app

  let auth_app = route_auth_dto(
    app(),
    "/auth-profile".as_slice(),
    method: Method::Get {},
    auth: required_session(),
    timeout: timeout_millis(5)
  ) do(session: String):
    let profile: TestProfile = { name: session, active: true }
    profile
  auth_app

  let auth_result_app = route_auth_result_dto(
    app(),
    "/auth-profile-result".as_slice(),
    method: Method::Get {},
    auth: required_session(),
    timeout: timeout_millis(5)
  ) do(session: String):
    let profile: TestProfile = { name: session, active: true }
    let value: Result<TestProfile, Response> = Ok<TestProfile> { value: profile }
    value
  auth_result_app

  let body_auth_app = route_body_auth_dto(
    app(),
    "/body-auth-profile".as_slice(),
    method: Method::Post {},
    body: text_body_policy(),
    auth: required_session(),
    timeout: timeout_millis(5)
  ) do(input: String, session: String):
    let name = session.concat(":".as_slice()).concat(input)
    let profile: TestProfile = { name: name, active: true }
    profile
  body_auth_app

  let body_auth_result_app = route_body_auth_result_dto(
    app(),
    "/body-auth-profile-result".as_slice(),
    method: Method::Post {},
    body: text_body_policy(),
    auth: required_session(),
    timeout: timeout_millis(5)
  ) do(input: String, session: String):
    let name = session.concat(":".as_slice()).concat(input)
    let profile: TestProfile = { name: name, active: true }
    let value: Result<TestProfile, Response> = Ok<TestProfile> { value: profile }
    value
  body_auth_result_app

  assert(true, eq: true)

test "dto route helpers compose with timeout policies":
  let body_app = route_body_dto(
    app(),
    "/body-dto-timeout".as_slice(),
    method: Method::Post {},
    body: text_body_policy(),
    timeout: timeout_millis(5)
  ) do(input: String):
    let profile: TestProfile = { name: input, active: true }
    profile
  body_app

  let body_result_app = route_body_result_dto(
    app(),
    "/body-result-dto-timeout".as_slice(),
    method: Method::Post {},
    body: text_body_policy(),
    timeout: timeout_millis(5)
  ) do(input: String):
    let profile: TestProfile = { name: input, active: true }
    let value: Result<TestProfile, Response> = Ok<TestProfile> { value: profile }
    value
  body_result_app

  let context_app = route_context_dto(
    app(),
    "/context-dto-timeout".as_slice(),
    method: Method::Get {},
    timeout: timeout_millis(5)
  ) do(_ctx: Context):
    let profile: TestProfile = { name: "ctx".as_slice().to_string(), active: true }
    profile
  context_app

  let context_result_app = route_context_result_dto(
    app(),
    "/context-result-dto-timeout".as_slice(),
    method: Method::Get {},
    timeout: timeout_millis(5)
  ) do(_ctx: Context):
    let profile: TestProfile = { name: "ctx".as_slice().to_string(), active: true }
    let value: Result<TestProfile, Response> = Ok<TestProfile> { value: profile }
    value
  context_result_app

  let query_app = route_query_context_dto(
    app(),
    "/query-dto-timeout".as_slice(),
    method: Method::Get {},
    timeout: timeout_millis(5)
  ) do(query: SearchQuery, _ctx: Context):
    let profile: TestProfile = { name: query.q, active: true }
    profile
  query_app

  let query_result_app = route_query_context_result_dto(
    app(),
    "/query-result-dto-timeout".as_slice(),
    method: Method::Get {},
    timeout: timeout_millis(5)
  ) do(query: SearchQuery, _ctx: Context):
    let profile: TestProfile = { name: query.q, active: true }
    let value: Result<TestProfile, Response> = Ok<TestProfile> { value: profile }
    value
  query_result_app

  let cookies_app = route_cookies_context_dto(
    app(),
    "/cookies-dto-timeout".as_slice(),
    method: Method::Get {},
    timeout: timeout_millis(5)
  ) do(cookies: TestCookies, _ctx: Context):
    let profile: TestProfile = { name: cookies.session, active: true }
    profile
  cookies_app

  let cookies_result_app = route_cookies_context_result_dto(
    app(),
    "/cookies-result-dto-timeout".as_slice(),
    method: Method::Get {},
    timeout: timeout_millis(5)
  ) do(cookies: TestCookies, _ctx: Context):
    let profile: TestProfile = { name: cookies.session, active: true }
    let value: Result<TestProfile, Response> = Ok<TestProfile> { value: profile }
    value
  cookies_result_app

  let params_app = route_params_context_dto(
    app(),
    "/params/:id".as_slice(),
    method: Method::Get {},
    timeout: timeout_millis(5)
  ) do(params: IdParams, _ctx: Context):
    let profile: TestProfile = { name: params.id, active: true }
    profile
  params_app

  let params_result_app = route_params_context_result_dto(
    app(),
    "/params-result/:id".as_slice(),
    method: Method::Get {},
    timeout: timeout_millis(5)
  ) do(params: IdParams, _ctx: Context):
    let profile: TestProfile = { name: params.id, active: true }
    let value: Result<TestProfile, Response> = Ok<TestProfile> { value: profile }
    value
  params_result_app

  let params_query_app = route_params_query_dto(
    app(),
    "/params-query/:id".as_slice(),
    method: Method::Get {},
    timeout: timeout_millis(5)
  ) do(params: IdParams, query: SearchQuery):
    let name = params.id.concat(":".as_slice()).concat(query.q)
    let profile: TestProfile = { name: name, active: true }
    profile
  params_query_app

  let params_query_result_app = route_params_query_result_dto(
    app(),
    "/params-query-result/:id".as_slice(),
    method: Method::Get {},
    timeout: timeout_millis(5)
  ) do(params: IdParams, query: SearchQuery):
    let name = params.id.concat(":".as_slice()).concat(query.q)
    let profile: TestProfile = { name: name, active: true }
    let value: Result<TestProfile, Response> = Ok<TestProfile> { value: profile }
    value
  params_query_result_app

  let params_query_context_app = route_params_query_context_dto(
    app(),
    "/params-query-context/:id".as_slice(),
    method: Method::Get {},
    timeout: timeout_millis(5)
  ) do(params: IdParams, query: SearchQuery, _ctx: Context):
    let name = params.id.concat(":".as_slice()).concat(query.q)
    let profile: TestProfile = { name: name, active: true }
    profile
  params_query_context_app

  let params_query_context_result_app = route_params_query_context_result_dto(
    app(),
    "/params-query-context-result/:id".as_slice(),
    method: Method::Get {},
    timeout: timeout_millis(5)
  ) do(params: IdParams, query: SearchQuery, _ctx: Context):
    let name = params.id.concat(":".as_slice()).concat(query.q)
    let profile: TestProfile = { name: name, active: true }
    let value: Result<TestProfile, Response> = Ok<TestProfile> { value: profile }
    value
  params_query_context_result_app

  assert(true, eq: true)

test "html document can include hydration model and client entry":
  let page: MsgPack =
    <main id="app">
      <h1>Hydrate</h1>
    </main>
  let model: TestProfile = { name: "Ada".as_slice().to_string(), active: true }
  let rendered = document<MsgPack, TestProfile>(
    view: page,
    hydrate: hydrate<TestProfile>(
      target: "#app".as_slice(),
      entry: "/assets/app.js".as_slice(),
      model: model
    )
  )

  assert(rendered.contains("<!doctype html>".as_slice()), eq: true)
  assert(rendered.contains("data-voyd-hydration=\"#app\"".as_slice()), eq: true)
  assert(rendered.contains("\"name\":\"Ada\"".as_slice()), eq: true)
  assert(rendered.contains("src=\"/assets/app.js\"".as_slice()), eq: true)
