  api fn post(self, path: StringSlice, { handler: fn() : (open) -> Response }) -> App
    self.with_unit_response_route(path, Method::Post {}, handler)

  api fn post<R: IntoResponse<R>>(self, path: String, { handler: fn() : (open) -> R }) -> App
