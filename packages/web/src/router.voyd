  api fn get_unit(self, path: StringSlice, { handler: fn() : (open) -> Response }) -> App
    self.with_unit_response_route(path, Method::Get {}, handler)

  api fn get_unit(self, path: String, { handler: fn() : (open) -> Response }) -> App
