  fn with_body_auth_route<I, P: FromBody<I>, S, A: FromAuth<S>, R: IntoResponse<R>>(
    self,
    path: StringSlice,
    {
      method: Method,
      body: P,
      auth: A,
      limit?: BodyLimit,
      timeout?: TimeoutPolicy,
      handler: fn(I, S) : (open) -> R,
      contract: RouteContract
    }
  ) -> App
    self.with_route_contract(path, method, (ctx: Context) -> Response =>
      apply_body_policies(ctx, limit: limit, timeout: timeout) do:
        match(body.extract_body(ctx.request))
          Err<Rejection> { error }:
            ctx.reject(error)
          Ok<I> { value: input }:
            match(auth.extract_auth(ctx.request))
              Ok<S> { value: session }:
                typed_response<R>(handler(input, session))
              Err<Rejection> { error }:
                ctx.reject(error)
    , contract: contract)

  fn with_json_body_auth_route<I, S, A: FromAuth<S>, T: IntoResponse<T>>(
    self,
    path: StringSlice,
    {
      method: Method,
      body: JsonBody,
      auth: A,
      limit?: BodyLimit,
      timeout?: TimeoutPolicy,
      handler: fn(I, S) : (open) -> T,
      contract: RouteContract
    }
  ) -> App
    self.with_route_contract(path, method, (ctx: Context) -> Response =>
      apply_body_policies(ctx, limit: limit, timeout: timeout) do:
        body
        match(json_body_value(ctx.request))
          Err<Rejection> { error }:
            ctx.reject(error)
          Ok<JsonValue> { value }:
            let input = decode_json_value<I>(value)
            match(auth.extract_auth(ctx.request))
              Ok<S> { value: session }:
                typed_response<T>(handler(input, session))
              Err<Rejection> { error }:
                ctx.reject(error)
    , contract: contract)

  fn with_params_route<P, T: IntoResponse<T>>(
    self,
    path: StringSlice,
    method: Method,
