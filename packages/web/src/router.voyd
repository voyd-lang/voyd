  api fn group(self, prefix: StringSlice, { routes build: fn(App) : (open) -> App }) -> App
    let child = App {
      routes: Array<Route>::init(),
      current_middleware: self.current_middleware.copied(),
      prefix: join_route_paths(self.prefix.as_slice(), prefix),
      next_order: self.next_order,
      not_found_handler: self.not_found_handler,
      method_not_allowed_handler: self.method_not_allowed_handler,
      error_handler: self.error_handler,
      trailing_slash_policy: self.trailing_slash_policy,
      openapi_info: self.openapi_info
    }

    let built = build(child)
    self.merge_routes(built.routes, next_order: built.next_order)

  api fn group(self, prefix: String, { routes build: fn(App) : (open) -> App }) -> App
    self.group(prefix.as_slice(), routes: build)

  api fn mount(self, prefix: StringSlice, router: Router) -> App
    self.mount(prefix, router.app)

  api fn mount(self, prefix: String, router: Router) -> App
    self.mount(prefix.as_slice(), router)

  api fn mount(self, prefix: StringSlice, app: App) -> App
    let routes = app.routes
    var out = self
    var index = 0
    while index < routes.len():
      match(routes.get(index))
        Some<Route> { value }:
          out = out.with_mounted_route(prefix, value)
        None:
          void
      index = index + 1
    out

  api fn not_found(self, handler: Handler) -> App
    App {
      routes: self.routes,
      current_middleware: self.current_middleware,
      prefix: self.prefix,
      next_order: self.next_order,
      not_found_handler: handler,
      method_not_allowed_handler: self.method_not_allowed_handler,
      error_handler: self.error_handler,
      trailing_slash_policy: self.trailing_slash_policy,
      openapi_info: self.openapi_info
    }

  api fn mount(self, prefix: String, app: App) -> App
    self.mount(prefix.as_slice(), app)

  api fn method_not_allowed(self, handler: Handler) -> App
    App {
      routes: self.routes,
      current_middleware: self.current_middleware,
      prefix: self.prefix,
      next_order: self.next_order,
      not_found_handler: self.not_found_handler,
      method_not_allowed_handler: handler,
      error_handler: self.error_handler,
      trailing_slash_policy: self.trailing_slash_policy,
      openapi_info: self.openapi_info
    }

  api fn on_error(self, handler: ErrorHandler) -> App
    App {
      routes: self.routes,
      current_middleware: self.current_middleware,
      prefix: self.prefix,
      next_order: self.next_order,
      not_found_handler: self.not_found_handler,
      method_not_allowed_handler: self.method_not_allowed_handler,
      error_handler: handler,
      trailing_slash_policy: self.trailing_slash_policy,
      openapi_info: self.openapi_info
    }

  api fn on_rejection(self, handler: ErrorHandler) -> App
    self.on_error(handler)

  /// Marks the first runtime-reachable route with this method and path as request-streaming.
  api fn streaming(self, path: StringSlice, { method: Method }) -> App
    self.mark_streaming(path, method: method)

  /// Returns the most recently added concrete route.
  api fn last_route(self) -> Option<RouteIdentity>
    if self.routes.is_empty():
      return None {}
    let route = self.routes.at(self.routes.len() - 1)
    Some<RouteIdentity> { value: RouteIdentity { method: route.method, path: route.path } }

  api fn handle(self, request: IncomingRequest): (open) -> Response
    self.handle_request(request, body: None {})

  /// Returns the application OpenAPI configuration, when enabled.
  api fn openapi_config(self) -> Option<OpenApiConfig>
    self.openapi_info

  /// Returns the route-owned contracts used by the automatic renderer.
  api fn openapi_routes(self) -> Array<RecordedOpenApiRoute>
    let ~out = Array<RecordedOpenApiRoute>::with_capacity(self.routes.len())
    var index = 0
    while index < self.routes.len():
      let route = self.routes.at(index)
      out.push(RecordedOpenApiRoute::init(
        method: route.method,
        path: route.path,
        runtime_key: runtime_route_key(route.path.as_slice(), self.trailing_slash_policy),
        contract: route.contract
      ))
      index = index + 1
    out

  /// Routes a request whose body is supplied as a lazy stream.
  api fn handle_streaming(
    self,
    request: IncomingRequest,
    body: RequestBody
  ): (open) -> Response
    self.handle_request(request, body: Some<RequestBody> { value: body })

  fn handler_for_route(self, route: Route) -> Handler
    match(route.openapi_exposure_include_doc_comments)
      Some<bool> { value: include_doc_comments }:
        let document = self.openapi(include_doc_comments: include_doc_comments)
        (_ctx: Context) -> Response => json_value(document)
      None:
        route.handler

  fn handle_request(
    self,
    request: IncomingRequest,
    { body: Option<RequestBody> }
  ): (open) -> Response
    let path = normalized_request_path(request.path, self.trailing_slash_policy)
    match(best_match(self.routes, request.method, path.as_slice(), self.trailing_slash_policy))
      Some<RouteMatch> { value }:
        let handler = self.handler_for_route(value.route)
        if value.route.streaming_request:
          let ctx = Context {
            request: request,
            route: MatchedRoute { path: value.route.path, params: value.params },
            request_body_stream: body,
            error_handler: value.route.error_handler
          }
          run_middleware(value.route.middleware, 0, ctx, handler)
        else:
          match(buffer_streaming_request(request, body))
            Err<HostError> { error }:
              streaming_body_read_error(error)
            Ok<IncomingRequest> { value: buffered_request }:
              let ctx = Context {
                request: buffered_request,
                route: MatchedRoute { path: value.route.path, params: value.params },
                request_body_stream: None {},
                error_handler: value.route.error_handler
              }
              run_middleware(value.route.middleware, 0, ctx, handler)
      None:
        let ctx = Context {
          request: request,
          route: MatchedRoute { path: path, params: RouteParams::empty() },
          request_body_stream: body,
          error_handler: self.error_handler
        }
        if path_matches_different_method(self.routes, path.as_slice(), self.trailing_slash_policy):
          let handler = self.method_not_allowed_handler
          run_middleware(self.current_middleware, 0, ctx, handler)
        else:
          let handler = self.not_found_handler
          run_middleware(self.current_middleware, 0, ctx, handler)

  fn with_context_route<T: IntoResponse<T>>(
    self,
    path: StringSlice,
    { method: Method, timeout?: TimeoutPolicy, handler: fn(Context) : (open) -> T, contract?: RouteContract }
  ) -> App
    let route_contract = match(contract)
      Some<RouteContract> { value }:
        value
      None:
        route_fragment(operation().with_responses(inferred_responses<T>()))
    self.with_route_contract(path, method, (ctx: Context) -> Response =>
      apply_body_policies(ctx, timeout: timeout) do:
        typed_response<T>(handler(ctx))
    , contract: route_contract)

  fn with_unit_contract_route(
    self,
    path: StringSlice,
    { method: Method, timeout?: TimeoutPolicy, handler: fn() : (open) -> Response, contract: RouteContract }
  ) -> App
    self.with_route_contract(path, method, (ctx: Context) -> Response =>
      apply_body_policies(ctx, timeout: timeout) do:
        handler()
    , contract: contract)

  fn with_auth_route<S, A: FromAuth<S>, R: IntoResponse<R>>(
    self,
    path: StringSlice,
    { method: Method, auth: A, timeout?: TimeoutPolicy, handler: fn(S) : (open) -> R }
  ) -> App
    self.with_route_contract(path, method, (ctx: Context) -> Response =>
      apply_body_policies(ctx, timeout: timeout) do:
        match(auth.extract_auth(ctx.request))
          Ok<S> { value }:
            typed_response<R>(handler(value))
          Err<Rejection> { error }:
            ctx.reject(error)
    , contract: route_fragment(operation().with_responses(inferred_responses<R>())))

