      handler()
    )

  fn with_params_query_route<P, Q, T: IntoResponse<T>>(
    self,
    path: StringSlice,
    method: Method,
    handler: fn(P, Q) : (open) -> T
  ) -> App
    self.with_route_contract(path, method, (ctx: Context) -> Response =>
      let params_source = ctx.route.params
      let query_source = ctx.query()
      match(validate_params<P>(RouteParams { entries: params_source.entries.copied() }))
        Some<Rejection> { value }:
          ctx.reject(value)
        None:
          match(validate_query<Q>(QueryParams { entries: query_source.entries.copied() }))
            Some<Rejection> { value }:
              ctx.reject(value)
            None:
              let result = handler(
                decode_params<P>(params_source),
                decode_query<Q>(query_source)
              )
              typed_response<T>(result)
    , contract: route_fragment(
      operation()
        .with_path_params<P>()
        .with_query<Q>()
        .with_responses(inferred_responses<T>())
    ))

  fn with_params_query_response_route<P, Q>(
    self,
    path: StringSlice,
    method: Method,
    handler: fn(P, Q) : (open) -> Response
  ) -> App
    self.with_route_contract(path, method, (ctx: Context) -> Response =>
      let params_source = ctx.route.params
      let query_source = ctx.query()
      match(validate_params<P>(RouteParams { entries: params_source.entries.copied() }))
        Some<Rejection> { value }:
          ctx.reject(value)
        None:
          match(validate_query<Q>(QueryParams { entries: query_source.entries.copied() }))
            Some<Rejection> { value }:
              ctx.reject(value)
            None:
              handler(
                decode_params<P>(params_source),
                decode_query<Q>(query_source)
              )
    , contract: route_fragment(
      operation().with_path_params<P>().with_query<Q>().with_opaque_response()
    ))

