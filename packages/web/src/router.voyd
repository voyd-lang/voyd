pub type Handler = fn(Context) : (open) -> Response
pub type Next = fn(Context) : (open) -> Response
pub type Middleware = fn(Context, Next) : (open) -> Response
pub type ErrorHandler = fn(Rejection, Context) : (open) -> Response

fn with_params_query<P, Q>(
  ctx: Context,
  work: fn(P, Q) : (open) -> Response
): (open) -> Response
  let query_source = ctx.query()
  match(extract_params<P>(ctx.route.params))
    Err<Rejection> { error }:
      ctx.reject(error)
    Ok<P> { value: params }:
      match(extract_query<Q>(query_source))
        Ok<Q> { value: query }:
          work(params, query)
        Err<Rejection> { error }:
          ctx.reject(error)

pub fn body_limit_rejection(ctx: Context, limit: BodyLimit): () -> Option<Response>
  if ctx.request.body.len() > limit.max_bytes:
    Some<Response> {
      value: ctx.reject(Rejection::payload_too_large("request body exceeds configured limit"))
    }
  else:
    None {}

fn apply_body_policies(
  ctx: Context,
  { limit?: BodyLimit, timeout?: TimeoutPolicy },
  work: fn() : (open) -> Response
): (task::TaskRuntime, Time, open) -> Response
  match(limit)
    Some<BodyLimit> { value }:
      match(body_limit_rejection(ctx, value))
        Some<Response> { value }:
          return value
        None:
          void
    None:
      void
  match(timeout)
    Some<TimeoutPolicy> { value }:
      run_with_timeout(value, work)
    None:
      work()

pub obj AuthError {
  api message: String
}

pub obj MatchedRoute {
  api path: String,
  api params: RouteParams
}

pub obj Context {
  api request: IncomingRequest,
  api route: MatchedRoute,
  request_body_stream?: RequestBody,
  error_handler: ErrorHandler
}

pub obj TrailingSlashPolicy {
  kind: i32
}

obj RouteSegment {
  kind: i32,
  value: String
}

pub obj Route {
  method: Method,
  path: String,
  segments: Array<RouteSegment>,
  middleware: Array<Middleware>,
  handler: Handler,
  error_handler: ErrorHandler,
  streaming_request: bool,
  openapi_exposure_include_doc_comments?: bool,
  order: i32,
  contract: RouteContract
}

/// Method and path of one concrete router entry.
pub obj RouteIdentity {
  api method: Method,
  api path: String
}

/// Method, concrete path, and serialized contract for automatic OpenAPI.
obj RouteMatch {
  route: Route,
  params: RouteParams,
  score: i32
}

pub obj App {
  routes: Array<Route>,
  current_middleware: Array<Middleware>,
  prefix: String,
  next_order: i32,
  not_found_handler: Handler,
  method_not_allowed_handler: Handler,
  error_handler: ErrorHandler,
  trailing_slash_policy: TrailingSlashPolicy,
  openapi_info?: OpenApiConfig
}

pub obj Router {
  app: App
}

impl Router
  api fn init() -> Router
    Router { app: App::init() }

  api fn to_app(self) -> App
    self.app

pub type AppBuild = App

impl AuthError
  api fn init(message: StringSlice) -> AuthError
    AuthError { message: message.to_string() }

  api fn init(message: String) -> AuthError
    AuthError { message: message }

impl Context
  api fn method(self) -> Method
    self.request.method

  api fn path(self) -> String
    self.request.path

  api fn header(self, name: StringSlice) -> Option<String>
    self.request.header(name)

  api fn header(self, name: String) -> Option<String>
    self.request.header(name)

  api fn param(self, name: StringSlice) -> Option<String>
    self.route.params.get(name)

  api fn param(self, name: String) -> Option<String>
    self.param(name.as_slice())

  api fn query(self) -> QueryParams
    query_from(self.request)

  api fn query_value(self, name: StringSlice) -> Option<String>
    self.query().get(name)

  api fn query_value(self, name: String) -> Option<String>
    self.query_value(name.as_slice())

  api fn cookies(self) -> CookieJar
    cookies_from(self.request)

  api fn cookie(self, name: StringSlice) -> Option<String>
    self.cookies().get(name)

  api fn cookie(self, name: String) -> Option<String>
    self.cookie(name.as_slice())

  api fn body_bytes(self) -> Bytes
    self.request.body_bytes()

  /// Returns the lazy request body when the Web server enabled streaming.
  ///
  /// Buffered Web servers return `None`. The reader can be consumed once with
  /// `next()` and requires the `HttpServer` effect.
  api fn streaming_body(self) -> Option<RequestBody>
    self.request_body_stream

  api fn text(self) -> Result<String, http::HttpError>
    self.request.text()

  api fn json(self) -> Result<JsonValue, http::HttpError>
    self.request.json()

  api fn reject(self, rejection: Rejection) -> Response
    let handler = self.error_handler
    handler(rejection, self)

impl TrailingSlashPolicy
  api fn strict() -> TrailingSlashPolicy
    TrailingSlashPolicy { kind: 0 }

  api fn ignore() -> TrailingSlashPolicy
    TrailingSlashPolicy { kind: 1 }

impl App
  api fn init() -> App
    App {
      routes: Array<Route>::init(),
      current_middleware: Array<Middleware>::init(),
      prefix: String::init(),
      next_order: 0,
      not_found_handler: (ctx: Context) -> Response => default_not_found(ctx),
      method_not_allowed_handler: (ctx: Context) -> Response => default_method_not_allowed(ctx),
      error_handler: (rejection: Rejection, ctx: Context) -> Response => default_rejection(rejection, ctx),
      trailing_slash_policy: TrailingSlashPolicy::strict(),
      openapi_info: None {}
    }

  api fn init({ openapi: OpenApiConfig }) -> App
    let base = App::init()
    App {
      routes: base.routes,
      current_middleware: base.current_middleware,
      prefix: base.prefix,
      next_order: base.next_order,
      not_found_handler: base.not_found_handler,
      method_not_allowed_handler: base.method_not_allowed_handler,
      error_handler: base.error_handler,
      trailing_slash_policy: base.trailing_slash_policy,
      openapi_info: Some<OpenApiConfig> { value: openapi }
    }

  /// Renders OpenAPI 3.1 from the contracts owned by this app's routes.
  api fn openapi(self, { include_doc_comments: bool = true }) -> JsonValue
    render_openapi(
      self.openapi_routes(),
      self.openapi_config(),
      include_doc_comments: include_doc_comments
    )

  /// Exposes this app's OpenAPI document without documenting the exposure route.
  api fn expose_openapi(
    self,
    { at path: StringSlice, include_doc_comments: bool = true }
  ) -> App
    self.with_openapi_exposure(
      path,
      include_doc_comments: include_doc_comments
    )

  api fn expose_openapi(
    self,
    { at path: String, include_doc_comments: bool = true }
  ) -> App
    self.expose_openapi(at: path.as_slice(), include_doc_comments: include_doc_comments)

  /// Adds a hidden route that serves an already-built OpenAPI document.
  /// This is the route-owned bridge used by the low-level manual builder.
  api fn expose_openapi_document(
    self,
    path: StringSlice,
    { handler: fn() : (open) -> Response }
  ) -> App
    self.with_route_entry(
      path,
      Method::Get {},
      (_ctx: Context) -> Response => handler(),
      contract: hidden_fragment(),
      openapi_exposure_include_doc_comments: None<bool> {}
    )

  api fn expose_openapi_document(
    self,
    path: String,
    { handler: fn() : (open) -> Response }
  ) -> App
    self.expose_openapi_document(path.as_slice(), handler: handler)

  /// Applies documentation to the first runtime-reachable route with this
  /// method and normalized runtime path. This keeps advanced metadata available across
  /// every specialized route helper without duplicating their overloads.
  api fn with_route_docs(
    self,
    path: StringSlice,
    { method: Method, docs: RouteDocs }
  ) -> App
    let full_path = join_route_paths(self.prefix.as_slice(), path)
    let ~routes = self.routes.copied()
    let runtime_key = runtime_route_key(full_path.as_slice(), self.trailing_slash_policy)
    var index = 0
    var documented = false
    while index < routes.len() and not documented:
      let route = routes.at(index)
      if methods_equal(route.method, method) and runtime_route_key(
        route.path.as_slice(),
        self.trailing_slash_policy
      ).equals(runtime_key):
        let updated = Route {
          method: route.method,
          path: route.path,
          segments: route.segments,
          middleware: route.middleware,
          handler: route.handler,
          error_handler: route.error_handler,
          streaming_request: route.streaming_request,
          openapi_exposure_include_doc_comments: route.openapi_exposure_include_doc_comments,
          order: route.order,
          contract: apply_route_docs(route.contract, docs)
        }
        let _ = routes.replace(index, with: updated)
        documented = true
      index = index + 1
    App {
      routes: routes,
      current_middleware: self.current_middleware,
      prefix: self.prefix,
      next_order: self.next_order,
      not_found_handler: self.not_found_handler,
      method_not_allowed_handler: self.method_not_allowed_handler,
      error_handler: self.error_handler,
      trailing_slash_policy: self.trailing_slash_policy,
      openapi_info: self.openapi_info
    }

  api fn with_route_docs(
    self,
    path: String,
    { method: Method, docs: RouteDocs }
  ) -> App
    self.with_route_docs(path.as_slice(), method: method, docs: docs)

  api fn adopt(self, middleware: Middleware) -> App
    let ~next_middleware = self.current_middleware.copied(1)
    next_middleware.push(middleware)
    App {
      routes: self.routes,
      current_middleware: next_middleware,
      prefix: self.prefix,
      next_order: self.next_order,
      not_found_handler: self.not_found_handler,
      method_not_allowed_handler: self.method_not_allowed_handler,
      error_handler: self.error_handler,
      trailing_slash_policy: self.trailing_slash_policy,
      openapi_info: self.openapi_info
    }

  api fn with(self, { trailing_slash: TrailingSlashPolicy }) -> App
    App {
      routes: self.routes,
      current_middleware: self.current_middleware,
      prefix: self.prefix,
      next_order: self.next_order,
      not_found_handler: self.not_found_handler,
      method_not_allowed_handler: self.method_not_allowed_handler,
      error_handler: self.error_handler,
      trailing_slash_policy: trailing_slash,
      openapi_info: self.openapi_info
    }

  api fn get<R: IntoResponse<R>>(self, path: StringSlice, { handler: fn(Context) : (open) -> R }) -> App
    self.route<R>(path, method: Method::Get {}, handler: handler)

  api fn get(self, path: StringSlice, { handler: Handler }) -> App
    self.with_route(path, Method::Get {}, handler)

  api fn get<R: IntoResponse<R>>(self, path: String, { handler: fn(Context) : (open) -> R }) -> App
    self.get<R>(path.as_slice(), handler: handler)

  api fn get(self, path: String, { handler: Handler }) -> App
    self.get(path.as_slice(), handler: handler)

  api fn get<R: IntoResponse<R>>(self, path: StringSlice, { handler: fn() : (open) -> R }) -> App
    self.route<R>(path, method: Method::Get {}, handler: handler)

  api fn get(self, path: StringSlice, { handler: fn() : (open) -> Response }) -> App
    self.with_unit_response_route(path, Method::Get {}, handler)

  api fn get<R: IntoResponse<R>>(self, path: String, { handler: fn() : (open) -> R }) -> App
