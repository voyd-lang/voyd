impl Router
  api fn get_params<P, R: IntoResponse<R>>(self, path: StringSlice, { handler: fn(P) : (open) -> R }) -> Router
    Router { app: self.app.get_params<P, R>(path, handler: handler) }

  api fn get_params_query<P, Q, R: IntoResponse<R>>(self, path: StringSlice, { handler: fn(P, Q) : (open) -> R }) -> Router
    Router { app: self.app.get_params_query<P, Q, R>(path, handler: handler) }

  api fn post_params<P, R: IntoResponse<R>>(self, path: StringSlice, { handler: fn(P) : (open) -> R }) -> Router
    Router { app: self.app.post_params<P, R>(path, handler: handler) }

  api fn post_params_query<P, Q, R: IntoResponse<R>>(self, path: StringSlice, { handler: fn(P, Q) : (open) -> R }) -> Router
    Router { app: self.app.post_params_query<P, Q, R>(path, handler: handler) }

  api fn post<I, R: IntoResponse<R>>(
      self,
      path: StringSlice,
      { body: JsonBody, limit?: BodyLimit, timeout?: TimeoutPolicy, handler: fn(I) : (open) -> R, docs: RouteDocs }
    ) -> Router
    Router { app: self.app.with_json_body_route<I, R>(path, method: Method::Post {}, body: body, limit: limit, timeout: timeout, handler: handler, contract: typed_json_fragment<I, R>(docs)) }

