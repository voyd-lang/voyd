  ) -> App
    self.with_route_contract(path, method, (ctx: Context) -> Response =>
      match(extract_params<P>(ctx.route.params))
        Ok<P> { value }:
          let result = handler(value)
          typed_response<T>(result)
        Err<Rejection> { error }:
          ctx.reject(error)
    , contract: route_fragment(
      operation().with_path_params<P>().with_responses(inferred_responses<T>())
