use src::openapi::{ document, info, operation, operation_with_request }
use src::contract::{ OpenApiRequestContract, OpenApiResponse, OpenApiResponseContract, openapi_json_response, route_docs }
use src::contract::openapi_response as response_override
use src::phase3_openapi_types::{
  DocumentedArticle,
  DocumentedArticlePath,
  DocumentedArticleQuery,
  DocumentedCreateArticle,
  DocumentedEvent,
  DocumentedRecursivePair,
  AutomaticArticle,
  AutomaticCreateArticle
}
use std::array::Array
use std::http::{ Method, Response }
use std::json::stringify
use std::error::panic
use std::optional::types::all
use std::result::types::all
use std::string::type::{ String, StringSlice }
use std::test::assertions::all
use src::extract::json_body
use src::response::{ Accepted, Created, Json, NoContent, Text, created, text }
use src::response_docs::inferred_responses
use src::router::{ App, Context, Router, app }
use src::automatic_openapi::all

fn create_automatic_article(input: AutomaticCreateArticle) -> Created<AutomaticArticle>
  created(AutomaticArticle { id: 1, title: input.title })

obj CustomReply {
  api message: String
}

impl OpenApiResponse<CustomReply> for CustomReply
  fn openapi_responses() -> Array<OpenApiResponseContract>
    [openapi_json_response<AutomaticArticle>(status: 203, description: "Custom response")]

fn raw_reply(_input: AutomaticCreateArticle): (open) -> Response
  Response::ok().text("raw")

test "OpenAPI reflects record fields and doc comments":
  let base_operation = operation(
    summary: "Create an article".as_slice().to_string(),
    description: "Creates and returns one article.".as_slice().to_string(),
    operation_id: "createArticle".as_slice().to_string(),
    response_status: 201,
    response_description: "Article created".as_slice().to_string()
  )
  let with_path = base_operation.with_path_params<DocumentedArticlePath>()
  let with_query = with_path.with_query<DocumentedArticleQuery>()
  let with_body = with_query.with_json_body<DocumentedCreateArticle>()
  let create_operation = with_body.responds_json<DocumentedArticle>()
  let events_base = operation(summary: "Watch events".as_slice().to_string())
  let events_operation = events_base.responds_sse<DocumentedEvent>()
  let spec_base = document(info(
    title: "Article API".as_slice(),
    version: "1.0.0".as_slice(),
    description: "Example API".as_slice().to_string()
  ))
  let article_spec = spec_base.route(
    "/articles/:id".as_slice(), method: Method::Post {}, operation: create_operation
  )
  let events_spec = article_spec.route(
    "/events".as_slice(), method: Method::Get {}, operation: events_operation
  )
  let spec = events_spec.route(
    "/recursive".as_slice(),
    method: Method::Get {},
    operation: operation().responds_json<DocumentedRecursivePair>()
  )

  match(stringify(spec.json()))
    Err:
      Test::fail()
    Ok<String> { value }:
      require_contains(value, "\"openapi\":\"3.1.0\"".as_slice(), "missing version")
      require_contains(value, "\"/articles/{id}\"".as_slice(), "missing path")
      require_contains(value, "\"operationId\":\"createArticle\"".as_slice(), "missing operation id")
      require_contains(value, "Stable article identifier.".as_slice(), "missing path documentation")
      require_contains(value, "Reader-visible article title.".as_slice(), "missing field documentation")
      require_contains(value, "\"required\":[\"title\"]".as_slice(), "missing required field")
      require_contains(value, "\"text/event-stream\"".as_slice(), "missing SSE content")
      require_contains(value, "\"x-voyd-event-schema\"".as_slice(), "missing SSE event schema")
      require_contains(value, "%23".as_slice(), "recursive component ref is not URI escaped")
      require_contains(
        value,
        "DocumentedRecursivePair_".as_slice(),
        "recursive component identity is not type based"
      )

test "app-owned OpenAPI derives JSON request and created response contracts":
  let article_app = app(openapi: {
    title: "Articles API",
    version: "1.0.0",
    description: "Automatic API"
  }).post(
    "/automatic/articles",
    body: json_body(),
    handler: create_automatic_article,
    docs: {
      description: "Create an article",
      operation_id: "createArticle",
      tags: ["articles"]
    }
  )
  match(stringify(article_app.openapi()))
    Err:
      Test::fail()
    Ok<String> { value }:
      require_contains(value, "\"/automatic/articles\"".as_slice(), "missing automatic path")
      require_contains(value, "\"201\"".as_slice(), "missing created status")
      require_contains(value, "\"application/json\"".as_slice(), "missing JSON media type")
      require_contains(value, "Reader-visible article title.".as_slice(), "missing doc comments")

  match(stringify(article_app.openapi(include_doc_comments: false)))
    Err:
      Test::fail()
    Ok<String> { value }:
      assert(value.contains("Reader-visible article title.".as_slice()), eq: false)
      require_contains(value, "Create an article".as_slice(), "explicit docs were removed")

test "typed JSON routes infer responses without route metadata":
  let article_app = app(openapi: { title: "Articles API", version: "1.0.0" })
    .post("/articles", body: json_body(), handler: create_automatic_article)
  match(stringify(article_app.openapi()))
    Err:
      Test::fail()
    Ok<String> { value }:
      require_contains(value, "\"201\"".as_slice(), "missing inferred created status")
      require_contains(value, "\"application/json\"".as_slice(), "missing inferred JSON response")

test "automatic OpenAPI hides routes and is deterministic":
  let hidden_app = app(openapi: { title: "Hidden", version: "1" })
    .post(
      "/visible",
      body: json_body(),
      handler: create_automatic_article,
      docs: { operation_id: "visible", hidden: false }
    )
    .post(
      "/hidden",
      body: json_body(),
      handler: create_automatic_article,
      docs: { hidden: true }
    )
  match(stringify(hidden_app.openapi()))
    Err:
      Test::fail()
    Ok<String> { value: first }:
      assert(first.contains("\"/hidden\"".as_slice()), eq: false)
      match(stringify(hidden_app.openapi()))
        Ok<String> { value: second }:
          assert(first, eq: second)
        Err:
          Test::fail()

test "typed response contracts cover statuses text result and option":
  let spec = document(info(title: "Responses", version: "1"))
    .route("/created", method: Method::Get {}, operation: operation().with_responses(inferred_responses<Created<AutomaticArticle>>()))
    .route("/accepted", method: Method::Get {}, operation: operation().with_responses(inferred_responses<Accepted<AutomaticArticle>>()))
    .route("/empty", method: Method::Get {}, operation: operation().with_responses(inferred_responses<NoContent>()))
    .route("/text", method: Method::Get {}, operation: operation().with_responses(inferred_responses<Text>()))
    .route("/result", method: Method::Get {}, operation: operation().with_responses(inferred_responses<Result<Created<AutomaticArticle>, Accepted<AutomaticArticle>>>() ))
    .route("/option", method: Method::Get {}, operation: operation().with_responses(inferred_responses<Option<Json<AutomaticArticle>>>() ))
  match(stringify(spec.json()))
    Err:
      Test::fail()
    Ok<String> { value }:
      require_contains(value, "\"201\"".as_slice(), "missing created response")
      require_contains(value, "\"202\"".as_slice(), "missing accepted response")
      require_contains(value, "\"204\"".as_slice(), "missing no-content response")
      require_contains(value, "\"404\"".as_slice(), "missing option not-found response")
      require_contains(value, "\"text/plain\"".as_slice(), "missing text response")

test "request overrides and same-status response media types are preserved":
  let request = OpenApiRequestContract {
    description: Some<String> { value: "Optional input".to_string() },
    content_type: "application/json".to_string(),
    schema: None {},
    required: false
  }
  let spec = document(info(title: "Overrides", version: "1"))
    .route(
      "/merge",
      method: Method::Post {},
      operation: operation_with_request(operation(), request)
        .with_responses([
          openapi_json_response<AutomaticArticle>(status: 200, description: "JSON"),
          response_override(
            status: 200,
            description: "Text".to_string(),
            content_type: Some<String> { value: "text/plain".to_string() }
          )
        ])
    )
  match(stringify(spec.json()))
    Err:
      Test::fail()
    Ok<String> { value }:
      require_contains(value, "Optional input".as_slice(), "missing request description")
      require_contains(value, "\"required\":false".as_slice(), "missing optional request body")
      require_contains(value, "\"application/json\"".as_slice(), "missing JSON response alternative")
      require_contains(value, "\"text/plain\"".as_slice(), "missing text response alternative")

test "raw and custom responses use explicit response documentation":
  let custom_spec = document(info(title: "Custom", version: "1"))
    .route("/custom", method: Method::Get {}, operation: operation().with_responses(CustomReply::openapi_responses()))
    .route("/raw-override", method: Method::Get {}, operation: operation().with_responses([
      openapi_json_response<AutomaticArticle>(status: 206, description: "Partial article")
    ]))
  let documented = app(openapi: { title: "Overrides", version: "1" })
    .post(
      "/raw".as_slice(),
      body: json_body(),
      handler: raw_reply,
      docs: route_docs(responses: [
        openapi_json_response<AutomaticArticle>(status: 206, description: "Partial article")
      ])
    )
  match(stringify(custom_spec.json()))
    Err:
      Test::fail()
    Ok<String> { value }:
      require_contains(value, "\"203\"".as_slice(), "missing custom response contract")
      require_contains(value, "\"206\"".as_slice(), "missing response override")
  match(stringify(documented.openapi()))
    Err:
      Test::fail()
    Ok<String> { value }:
      require_contains(value, "\"/raw\"".as_slice(), "missing raw response route")
      require_contains(value, "\"206\"".as_slice(), "missing raw response override")

test "grouping mounting and exposure preserve route-owned contracts":
  let grouped = app(openapi: { title: "Composition", version: "1" })
    .group("/v1", routes: (child: App) -> App =>
      child.get("/health", handler: () -> Text => text("ok"))
    )
  let mounted = app(openapi: { title: "Mounted", version: "1" })
    .mount("/api", grouped)
    .expose_openapi(at: "/openapi.json")
  match(stringify(mounted.openapi()))
    Err:
      Test::fail()
    Ok<String> { value }:
      require_contains(value, "\"/api/v1/health\"".as_slice(), "missing mounted grouped path")
      assert(value.contains("\"/openapi.json\"".as_slice()), eq: false)

fn require_contains(value: String, needle: StringSlice, message: String) -> void
  if not value.contains(needle):
    panic(message)
