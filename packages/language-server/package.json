{
  "name": "@voyd-lang/language-server",
  "version": "0.1.0",
  "description": "Voyd language server",
  "type": "module",
  "main": "./dist/index.js",
  "files": [
    "dist"
  ],
  "bin": {
    "voyd-language-server": "./dist/server.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "development": "./src/server.ts",
      "import": "./dist/server.js",
      "default": "./dist/server.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run --config ../../vitest.config.ts --maxWorkers=50% --minWorkers=1 src",
    "test:w": "vitest --config ../../vitest.config.ts src",
    "lint": "echo 'no lint configured'",
    "prepack": "npm run clean && npm run build",
    "prepublishOnly": "node ../../scripts/release/enforce-workspace-release.mjs"
  },
  "dependencies": {
    "@voyd-lang/compiler": "^0.1.0",
    "@voyd-lang/std": "^0.1.0",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12",
    "vscode-uri": "^3.0.8"
  }
}
