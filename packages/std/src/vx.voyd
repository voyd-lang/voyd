pub fn program<Model, Msg>({
  model: Model,
  frame?: Html<Msg>,
  commands?: Cmd<Msg>,
  subscriptions?: Sub<Msg>
}) -> Program<Model, Msg>
  let ~out = Dict<String, MsgPack>::init()
  out.set("$vx", "runtime_result")
  out.set("model", boundary_value_to_msgpack(model))
  if frame is Some:
    out.set("frame", frame.value)
  if commands is Some:
    out.set("commands", commands.value.payload)
  if subscriptions is Some:
    out.set("subscriptions", subscriptions.value.payload)
  Program<Model, Msg> { payload: msgpack::make_map(out) }

/// Creates the next program transition from an explicit model.
pub fn next<Model, Msg>(model: Model) -> Program<Model, Msg>
  program<Model, Msg>(model: model)

/// Creates the next program transition with one command.
pub fn next<Model, Msg>({ model: Model, cmd: Cmd<Msg> }) -> Program<Model, Msg>
  program<Model, Msg>(model: model, commands: cmd)

/// Lifts a child program result through a retained model mapper.
pub fn map_model<Model, NextModel, Msg>({
  program: Program<Model, Msg>,
  handler_id: i32,
  hydrate_handler_id?: i32
}) -> Program<NextModel, Msg>
  let ~out = Dict<String, MsgPack>::init()
  out.set("kind", "program_map_model")
  out.set("child", program.payload)
  out.set("handlerId", msgpack::make_i32(handler_id))
  if hydrate_handler_id is Some:
    out.set("hydrateHandlerId", msgpack::make_i32(hydrate_handler_id.value))
  Program<NextModel, Msg> { payload: msgpack::make_map(out) }

/// Lifts a child program result through a typed model mapper.
pub fn map_model<Model, NextModel, Msg>(
  program: Program<Model, Msg>,
  handler: fn(Model) -> NextModel
) -> Program<NextModel, Msg>
  map_model<Model, NextModel, Msg>(
    program: program,
    handler_id: retain_program_callback_id(handler)
  )

/// Lifts a child program through model mappers in both runtime directions.
/// The hydrate mapper is required when the mapped program adopts an SSR model.
pub fn map_model<Model, NextModel, Msg>({
  program: Program<Model, Msg>,
  map: fn(Model) -> NextModel,
  hydrate: fn(NextModel) -> Model
}) -> Program<NextModel, Msg>
  map_model<Model, NextModel, Msg>(
    program: program,
    handler_id: retain_program_callback_id(map),
    hydrate_handler_id: retain_program_callback_id(hydrate)
  )

/// Lifts a child program result through a retained message mapper.
pub fn map_message<Model, ChildMsg, ParentMsg>({
  program: Program<Model, ChildMsg>,
  handler_id: i32
}) -> Program<Model, ParentMsg>
  let ~out = Dict<String, MsgPack>::init()
  out.set("kind", "program_map_message")
  out.set("child", program.payload)
  out.set("handlerId", msgpack::make_i32(handler_id))
  Program<Model, ParentMsg> { payload: msgpack::make_map(out) }

/// Lifts a child program result through a typed message mapper.
pub fn map_message<Model, ChildMsg, ParentMsg>(
  program: Program<Model, ChildMsg>,
  handler: fn(ChildMsg) -> ParentMsg
) -> Program<Model, ParentMsg>
  map_message<Model, ChildMsg, ParentMsg>(
    program: program,
    handler_id: retain_program_callback_id(handler)
  )

pub fn program<Model, Msg>({
  init: fn() : (open) -> Model,
  hydrate: fn(Model) : (open) -> Program<Model, Msg> = ((model: Model) : (open) -> Program<Model, Msg>) => next(model),
  step: fn(Model, Msg) : (open) -> Program<Model, Msg>,
  view: fn(Model) : (open) -> Html<Msg>,
  subscriptions: fn(Model) : (open) -> Sub<Msg> = ((_model: Model) : (open) -> Sub<Msg>) => Sub<Msg>::none()
}) -> Program<Model, Msg>
  program_handlers<Model, Msg>(
    init_id: retain_program_callback_id(init),
    hydrate_id: retain_program_callback_id(hydrate),
    step_id: retain_program_callback_id(step),
    view_id: retain_program_callback_id(view),
    subscriptions_id: retain_program_callback_id(subscriptions)
  )

pub fn program<Model, Msg>({
  init: fn() : (open) -> Program<Model, Msg>,
  hydrate: fn(Model) : (open) -> Program<Model, Msg> = ((model: Model) : (open) -> Program<Model, Msg>) => next(model),
  step: fn(Model, Msg) : (open) -> Program<Model, Msg>,
  view: fn(Model) : (open) -> Html<Msg>,
  subscriptions: fn(Model) : (open) -> Sub<Msg> = ((_model: Model) : (open) -> Sub<Msg>) => Sub<Msg>::none()
}) -> Program<Model, Msg>
  program_handlers<Model, Msg>(
    init_id: retain_program_callback_id(init),
    hydrate_id: retain_program_callback_id(hydrate),
    step_id: retain_program_callback_id(step),
    view_id: retain_program_callback_id(view),
    subscriptions_id: retain_program_callback_id(subscriptions)
  )

fn program_handlers<Model, Msg>({
  init_id: i32,
  hydrate_id: i32,
  step_id: i32,
  view_id: i32,
  subscriptions_id?: i32
}) -> Program<Model, Msg>
  let ~out = Dict<String, MsgPack>::init()
  out.set("kind", "program")
  out.set("initHandlerId", msgpack::make_i32(init_id))
  out.set("hydrateHandlerId", msgpack::make_i32(hydrate_id))
  out.set("stepHandlerId", msgpack::make_i32(step_id))
  out.set("viewHandlerId", msgpack::make_i32(view_id))
  if subscriptions_id is Some:
    out.set("subscriptionsHandlerId", msgpack::make_i32(subscriptions_id.value))
  Program<Model, Msg> { payload: msgpack::make_map(out) }

/// Creates a virtual DOM element payload for renderer consumption.
///
/// The returned value is a MsgPack map with `name`, `children`, and optional `attributes`.
pub fn create_element({
  /// Element tag or component identifier.
  name: String,
  /// Optional list of two-item key/value MsgPack pairs.
  attributes?: Array<Array<MsgPack>>,
  /// Ordered child node payloads.
  children: Array<MsgPack>
}) -> MsgPack
  let ~element = Dict<String, MsgPack>::init()
  element.set("name", name)
  element.set("children", children)
  if attributes is Some:
    let attrs = attributes_to_map(attributes.value)
    element.set("attributes", msgpack::make_map(attrs))
  msgpack::make_map(element)

obj NormalizedAttrs {
  attrs: Dict<String, MsgPack>,
  props: Dict<String, MsgPack>,
  styles: Dict<String, MsgPack>,
  events: Array<MsgPack>
}

fn normalize_attrs(attributes: Array<MsgPack>): () -> NormalizedAttrs
  let ~attrs = Dict<String, MsgPack>::init()
  let ~props = Dict<String, MsgPack>::init()
  let ~styles = Dict<String, MsgPack>::init()
  let ~events = Array<MsgPack>::init()
  var index = 0
  while index < attributes.len():
    match(attributes.get(index))
      Some<MsgPack> { value }:
        match(msgpack::unpack_map(value))
          Ok<Dict<String, MsgPack>> { value: entry }:
            consume_attr_entry(entry, attrs, props, styles, events)
          Err:
            void
      None:
        void
    index = index + 1
  NormalizedAttrs { attrs: attrs, props: props, styles: styles, events: events }

fn consume_attr_entry(
  entry: Dict<String, MsgPack>,
  ~attrs: Dict<String, MsgPack>,
  ~props: Dict<String, MsgPack>,
  ~styles: Dict<String, MsgPack>,
  ~events: Array<MsgPack>
) -> void
  match(entry.get("kind"))
    Some<MsgPack> { value }:
      match(msgpack::unpack_string(value))
        Ok<String> { value: kind }:
          if kind == "event":
            events.push(msgpack::make_map(entry))
          else:
            if kind == "style":
              consume_named_attr(entry, styles)
            else:
              if kind == "prop":
                consume_named_attr(entry, props)
              else:
                consume_named_attr(entry, attrs)
        Err:
          void
    None:
      void

fn consume_named_attr(entry: Dict<String, MsgPack>, ~attrs: Dict<String, MsgPack>) -> void
  match(entry.get("name"))
    Some<MsgPack> { value }:
      match(msgpack::unpack_string(value))
        Ok<String> { value: name }:
          match(entry.get("value"))
            Some<MsgPack> { value: attr_value }:
              attrs.set(name, attr_value)
            None:
              void
        Err:
          void
    None:
      void

fn bool_attr({ name: String, value: bool }): () -> MsgPack
  named_value("attr", name, msgpack::make_bool(value))

fn named_value(kind: String, name: String, value: MsgPack): () -> MsgPack
  let ~out = Dict<String, MsgPack>::init()
  out.set("kind", kind)
  out.set("name", name)
  out.set("value", value)
  msgpack::make_map(out)

fn named_value(kind: String, name: String, value: String): () -> MsgPack
  named_value(kind, name, msgpack::make_string(value))

fn join_classes(values: Array<String>): () -> String
  var out = String::init()
  var index = 0
  while index < values.len():
    match(values.get(index))
      Some<String> { value }:
        if out.byte_len() == 0:
          out = value
        else:
          out = out.concat(" ").concat(value)
      None:
        void
    index = index + 1
  out

fn event_options_to_map(options: EventOptions): () -> Dict<String, MsgPack>
  let ~out = Dict<String, MsgPack>::init()
  set_bool_option(out, "preventDefault", options.prevent_default)
  set_bool_option(out, "stopPropagation", options.stop_propagation)
  set_bool_option(out, "capture", options.capture)
  set_bool_option(out, "passive", options.passive)
  out

fn set_bool_option(~out: Dict<String, MsgPack>, name: String, value: Optional<bool>) -> void
  match(value)
    Some<bool> { value }:
      out.set(name, msgpack::make_bool(value))
    None:
      void

fn window_scroll_value({ x: f64, y: f64 }) -> MsgPack
  let ~out = Dict<String, MsgPack>::init()
  out.set("x", msgpack::make_f64(x))
  out.set("y", msgpack::make_f64(y))
  msgpack::make_map(out)

fn storage_entry_value({ key: String, value: String }) -> MsgPack
  let ~out = Dict<String, MsgPack>::init()
  out.set("key", key)
  out.set("value", value)
  msgpack::make_map(out)

fn open_url_value({ url: String, target: String }) -> MsgPack
  let ~out = Dict<String, MsgPack>::init()
  out.set("url", url)
  out.set("target", target)
  msgpack::make_map(out)

fn command_payload(kind: String): () -> MsgPack
  msgpack::make_map(command_map(kind))

fn command_map(kind: String): () -> Dict<String, MsgPack>
  tagged_vx_runtime_map("cmd", kind)

fn command_map_with_owned_handler(child: MsgPack, handler_id: i32): () -> Dict<String, MsgPack>
  let ~out = command_map("map")
  out.set("child", child)
  out.set("handlerId", msgpack::make_i32(handler_id))
  set_owned_handler(~out, handler_id)
  out

fn mark_owned_handler<Msg>(cmd: Cmd<Msg>, handler_id: i32) -> Cmd<Msg>
  match(msgpack::unpack_map(cmd.payload))
    Ok<Dict<String, MsgPack>> { value }:
      let ~out = value
      set_owned_handler(~out, handler_id)
      Cmd<Msg> { payload: msgpack::make_map(out) }
    Err:
      cmd

fn mark_owned_subscription<Msg>(sub: Sub<Msg>, handler_id: i32) -> Sub<Msg>
  match(msgpack::unpack_map(sub.payload))
    Ok<Dict<String, MsgPack>> { value }:
      let ~out = value
      set_owned_handler(~out, handler_id)
      Sub<Msg> { payload: msgpack::make_map(out) }
    Err:
      sub

fn set_owned_handler(~out: Dict<String, MsgPack>, handler_id: i32) -> void
  let ~owned = Array<MsgPack>::with_capacity(1)
  owned.push(msgpack::make_i32(handler_id))
  out.set("__vxOwnedMapHandlerIds", msgpack::make_array(owned))

fn subscription_payload(kind: String): () -> MsgPack
  msgpack::make_map(subscription_map(kind))

fn subscription_map(kind: String): () -> Dict<String, MsgPack>
  tagged_vx_runtime_map("sub", kind)

fn keyboard_subscription<Msg>({ kind: String, key: String, value: MsgPack }) -> Sub<Msg>
  let ~out = subscription_map("keyboard")
  out.set("key", key)
  out.set("event", kind)
  out.set("value", value)
  Sub<Msg> { payload: msgpack::make_map(out) }

fn keyboard_payload_subscription({ kind: String, key: String }) -> Sub<KeyboardEvent>
  let ~out = subscription_map("keyboard")
  out.set("key", key)
  out.set("event", kind)
  Sub<KeyboardEvent> { payload: msgpack::make_map(out) }

fn window_event_subscription<Msg>({
  kind: String,
  event: String,
  key: String,
  value: MsgPack
}) -> Sub<Msg>
  let ~out = subscription_map(kind)
  out.set("key", key)
  out.set("event", event)
  out.set("value", value)
  Sub<Msg> { payload: msgpack::make_map(out) }

fn window_event_payload_subscription({
  kind: String,
  event: String,
  key: String
}) -> Sub<GenericEvent>
  let ~out = subscription_map(kind)
  out.set("key", key)
  out.set("event", event)
  Sub<GenericEvent> { payload: msgpack::make_map(out) }

fn media_query_subscription<Msg>({ query: String, value: MsgPack }) -> Sub<Msg>
  let ~out = subscription_map("media_query")
  out.set("key", query)
  out.set("query", query)
  out.set("value", value)
  Sub<Msg> { payload: msgpack::make_map(out) }

fn media_query_payload_subscription(query: String) -> Sub<MediaQuery>
  let ~out = subscription_map("media_query")
  out.set("key", query)
  out.set("query", query)
  Sub<MediaQuery> { payload: msgpack::make_map(out) }

fn broadcast_channel_subscription<Msg>({ name: String, value: MsgPack }) -> Sub<Msg>
  let ~out = subscription_map("broadcast_channel")
  out.set("key", name)
  out.set("name", name)
  out.set("value", value)
  Sub<Msg> { payload: msgpack::make_map(out) }

fn broadcast_channel_payload_subscription<Payload>(name: String) -> Sub<Payload>
  let ~out = subscription_map("broadcast_channel")
  out.set("key", name)
  out.set("name", name)
  Sub<Payload> { payload: msgpack::make_map(out) }

fn tagged_vx_runtime_map(type_name: String, kind: String): () -> Dict<String, MsgPack>
  let ~out = Dict<String, MsgPack>::init()
  out.set("type", type_name)
  out.set("kind", kind)
  out

fn attributes_to_map(attributes: Array<Array<MsgPack>>): () -> Dict<String, MsgPack>
  let ~acc = Dict<String, MsgPack>::init()
  var index = 0
  while index < attributes.len():
    match(attributes.get(index))
      Some<Array<MsgPack>> { value: pair }:
        match(pair.get(0))
          Some<MsgPack> { value: key }:
            match(pair.get(1))
              Some<MsgPack> { value: value }:
                match(msgpack::unpack_string(key))
                  Ok<String> { value: name }:
                    acc.set(name, value)
                  Err:
                    panic("vx attribute key must decode as string".as_slice())
              None:
                void
          None:
            void
      None:
        void
    index = index + 1
  acc
