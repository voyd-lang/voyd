/// Reads a component-local serialized state handle.
pub fn state_handle({
  initial: MsgPack,
  id: i32 = stable_callsite_id()
}): Component -> StateHandle<MsgPack>
  state_handle_at(id: id, initial: initial)

fn state_handle_at({ id: i32, initial: MsgPack }): Component -> StateHandle<MsgPack>
  let slot = Component::state_key(id)
  StateHandle<MsgPack> {
    id: slot,
    value: Component::state_get(slot, initial)
  }

/// Reads a component-local text state handle.
pub fn state_handle({
  initial: String,
  id: i32 = stable_callsite_id()
}): Component -> StateHandle<String>
  state_handle_at(id: id, initial: initial)

fn state_handle_at({ id: i32, initial: String }): Component -> StateHandle<String>
  let slot = Component::state_key(id)
  StateHandle<String> {
    id: slot,
    value: component_string_state_value(
      value: Component::state_get(slot, msgpack::make_string(initial)),
      fallback: initial
    )
  }

pub fn state_handle({
  initial: StringSlice,
  id: i32 = stable_callsite_id()
}): Component -> StateHandle<String>
  state_handle_at(id: id, initial: initial.to_string())

/// Reads a component-local integer state handle.
pub fn state_handle({
  initial: i32,
  id: i32 = stable_callsite_id()
}): Component -> StateHandle<i32>
  state_handle_at(id: id, initial: initial)

fn state_handle_at({ id: i32, initial: i32 }): Component -> StateHandle<i32>
  let slot = Component::state_key(id)
  StateHandle<i32> {
    id: slot,
    value: component_i32_state_value(
      value: Component::state_get(slot, msgpack::make_i32(initial)),
      fallback: initial
    )
  }

/// Reads component-local serialized state as a `(value, setter)` pair.
pub fn state({
  initial: MsgPack,
  id: i32 = stable_callsite_id()
}): Component -> (MsgPack, fn(MsgPack) -> void)
  let handle = state_handle_at(id: id, initial: initial)
  (handle.value, (value: MsgPack) -> void => handle.set_serialized(value))

/// Reads component-local text state as a `(value, setter)` pair.
pub fn state({
  initial: String,
  id: i32 = stable_callsite_id()
}): Component -> (String, fn(String) -> void)
  let handle = state_handle_at(id: id, initial: initial)
  (handle.value, (value: String) -> void => handle.set(value))

pub fn state({
  initial: StringSlice,
  id: i32 = stable_callsite_id()
}): Component -> (String, fn(String) -> void)
  let handle = state_handle_at(id: id, initial: initial.to_string())
  (handle.value, (value: String) -> void => handle.set(value))

/// Reads component-local integer state as a `(value, setter)` pair.
pub fn state({
  initial: i32,
  id: i32 = stable_callsite_id()
}): Component -> (i32, fn(i32) -> void)
  let handle = state_handle_at(id: id, initial: initial)
  (handle.value, (value: i32) -> void => handle.set(value))

fn component_string_state_value({ value: MsgPack, fallback: String }): () -> String
  match(msgpack::unpack_string(value))
    Ok<String> { value }:
      value
    Err:
      fallback

fn component_i32_state_value({ value: MsgPack, fallback: i32 }): () -> i32
  match(msgpack::unpack_i32(value))
    Ok<i32> { value }:
      value
    Err:
      fallback

/// Registers a task with the current component instance.
pub fn task<T>({ key: MsgPack, task: Task<T> }): Component -> Unit
  Component::task_started(key, task.id)
  Unit {}

/// Retains a pure Voyd event callback in the host and returns its DOM handler id.
pub fn retain_event_handler(handler: fn() -> MsgPack): () -> i32
  retain_explicit_event_handler_id(handler)

/// Retains a component-local effect callback that does not dispatch an app message.
pub fn retain_event_handler(handler: fn() -> void): () -> i32
  retain_explicit_event_handler_void_id(handler)

/// Retains a pure Voyd event callback that receives the normalized event payload.
pub fn retain_event_payload_handler(handler: fn(MsgPack) -> MsgPack): () -> i32
  retain_explicit_event_handler_with_payload_id(handler)

/// Retains a pure Voyd message mapper for commands, subscriptions, or events.
pub fn retain_message_mapper(handler: fn(MsgPack) -> MsgPack): () -> i32
  retain_message_mapper_id(handler)

/// Retains a pure typed Voyd event callback in the host and returns its DOM handler id.
pub fn retain_typed_event_handler<Msg>(handler: fn() -> Msg): () -> i32
  retain_explicit_typed_event_handler_id(handler)

/// Retains a pure typed Voyd event callback that receives the normalized event payload.
