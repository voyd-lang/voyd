pub fn event_payload_handler<Event, Msg>({ name: StringSlice, handler: fn(Event) -> Msg, options?: EventOptions }): () -> MsgPack
  event_payload_handler<Event, Msg>(name: name.to_string(), handler: handler, options: options)

/// Creates an event descriptor that dispatches a serialized runtime message.
pub fn event({ name: String, message: MsgPack, options?: EventOptions }): () -> MsgPack
  let ~out = Dict<String, MsgPack>::init()
  out.set("kind", "event")
  out.set("event", name)
  out.set("message", message)
  if options is Some:
    out.set("options", msgpack::make_map(event_options_to_map(options.value)))
  msgpack::make_map(out)

pub fn event({ name: StringSlice, message: MsgPack, options?: EventOptions }): () -> MsgPack
  event(name: name.to_string(), message: message, options: options)

