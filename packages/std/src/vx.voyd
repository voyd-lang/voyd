  named_value("style", name, value)

pub fn style({ name: StringSlice, value: StringSlice }): () -> MsgPack
  style(name: name.to_string(), value: value.to_string())

pub fn styles(values: Array<(String, String)>): () -> Array<MsgPack>
  let ~out = Array<MsgPack>::with_capacity(values.len())
  var index = 0
  while index < values.len():
    match(values.get(index))
      Some<(String, String)> { value }:
        out.push(style(name: value.0, value: value.1))
      None:
        void
    index = index + 1
  out

pub fn keyed({ key: String, child: MsgPack }): () -> MsgPack
  match(msgpack::unpack_map(child))
    Ok<Dict<String, MsgPack>> { value }:
      let ~next = value
      next.set("key", key)
      msgpack::make_map(next)
    Err:
      child

pub fn keyed({ key: StringSlice, child: MsgPack }): () -> MsgPack
  keyed(key: key.to_string(), child: child)

pub fn keyed({ key: String, body: fn() -> MsgPack }): Component -> MsgPack
  Component::state_scope(msgpack::make_string(key))
  keyed(key: key, child: body())

pub fn keyed({ key: StringSlice, body: fn() -> MsgPack }): Component -> MsgPack
  keyed(key: key.to_string(), body: body)

/// Lifts child HTML through a retained message mapper.
pub fn map_html<ChildMsg, ParentMsg>({ html: Html<ChildMsg>, handler_id: i32 }) -> Html<ParentMsg>
  let ~out = Dict<String, MsgPack>::init()
  out.set("kind", "map")
  out.set("child", html)
  out.set("handlerId", msgpack::make_i32(handler_id))
  msgpack::make_map(out)

/// Creates an event descriptor from a host-retained handler id.
///
/// This is the low-level interop API for callers that need to manage retained
/// handlers explicitly. Higher-level helpers such as `on_click` forward to the
/// closure-backed shape or the static-message shape below.
pub fn event({ name: String, handler_id: i32, options?: EventOptions }): () -> MsgPack
  let ~out = Dict<String, MsgPack>::init()
  out.set("kind", "event")
  out.set("event", name)
  out.set("handlerId", msgpack::make_i32(handler_id))
  if options is Some:
    out.set("options", msgpack::make_map(event_options_to_map(options.value)))
  msgpack::make_map(out)

pub fn event_handler<Msg>({ name: String, handler: fn() -> Msg, options?: EventOptions }): () -> MsgPack
  event(name: name, handler_id: retain_typed_event_handler(handler), options: options)

pub fn event_handler<Msg>({ name: StringSlice, handler: fn() -> Msg, options?: EventOptions }): () -> MsgPack
  event_handler<Msg>(name: name.to_string(), handler: handler, options: options)

pub fn event({ name: String, handler: fn() -> MsgPack, options?: EventOptions }): () -> MsgPack
