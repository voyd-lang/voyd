use std::array::Array
use std::dict::{ Dict, DictKey }
use std::error::panic
use std::msgpack::self as msgpack
use std::optional::types::all
use std::result::types::Unit
use std::string::type::{ String, StringSlice, new_string }
use std::task::{ Task }
pub use std::msgpack::MsgPack

@boundary(type: "value")
pub type Html<Msg> = MsgPack
pub type HtmlNode = MsgPack
@boundary(type: "value")
pub type Attr<Msg> = MsgPack
pub type HtmlAttr = MsgPack
@boundary(type: "value")
pub type Program<Model, Msg> = MsgPack
pub type RenderKey = String

@boundary(type: "payload", field: "payload")
pub obj Cmd<Msg> {
  api payload: MsgPack
}

@boundary(type: "payload", field: "payload")
pub obj Sub<Msg> {
  api payload: MsgPack
}

pub obj EventOptions {
  api prevent_default?: bool,
  api stop_propagation?: bool,
  api capture?: bool,
  api passive?: bool
}

pub obj DomElement {}

pub obj Ref<T> {
  api id: String
}

pub obj StateHandle<T> {
  api id: i32,
  api value: T
}

pub type MouseEvent = {
  kind: String,
  x: f64,
  y: f64,
  client_x: f64,
  client_y: f64,
  button: i32,
  alt_key: bool,
  ctrl_key: bool,
  meta_key: bool,
  shift_key: bool,
  delta_x: f64,
  delta_y: f64
}

pub type KeyboardEvent = {
  kind: String,
  key: String,
  code: String,
  alt_key: bool,
  ctrl_key: bool,
  meta_key: bool,
  shift_key: bool
}

pub type InputEvent = {
  kind: String,
  value: String,
  checked: bool,
  input_type: String
}

pub type SubmitEvent = {
  kind: String,
  form_keys: Array<String>,
  form_values: Array<String>
}

pub type GenericEvent = {
  kind: String,
  event: String
}

@effect(id: "voyd.std.vx.dom")
pub eff Dom
  dispatch(tail, payload: MsgPack) -> MsgPack

@effect(id: "voyd.std.vx.component")
pub eff Component
  state_scope(tail, key: MsgPack) -> void

  state_key(tail, id: i32) -> i32

  state_get(tail, id: i32, initial: MsgPack) -> MsgPack

  state_set(tail, id: i32, value: MsgPack) -> void

  task_started(tail, key: MsgPack, task_id: i32) -> void

@intrinsic(name: "__retain_callback", uses_signature: true)
fn retain_event_handler_id(handler: fn() -> MsgPack): () -> i32
  0

@intrinsic(name: "__retain_callback", uses_signature: true)
fn retain_event_handler_void_id(handler: fn() -> void): () -> i32
  0

@intrinsic(name: "__retain_callback", uses_signature: true)
fn retain_event_handler_with_payload_id(handler: fn(MsgPack) -> MsgPack): () -> i32
  0

@intrinsic(name: "__retain_callback", uses_signature: true)
fn retain_typed_event_handler_id<Msg>(handler: fn() -> Msg): () -> i32
  __retain_callback(handler)

@intrinsic(name: "__retain_callback", uses_signature: true)
fn retain_typed_event_handler_with_payload_id<Event, Msg>(handler: fn(Event) -> Msg): () -> i32
  __retain_callback(handler)

@intrinsic(name: "__stable_callsite_id")
fn stable_callsite_id(): () -> i32
  0

@intrinsic(name: "__boundary_value_to_msgpack")
fn boundary_value_to_msgpack<Msg>(message: Msg): () -> MsgPack
  __boundary_value_to_msgpack(message)

impl StateHandle<MsgPack>
  /// Replaces component-local serialized state and schedules the component runtime.
  api fn set_serialized(self, value: MsgPack): Component -> void
    Component::state_set(self.id, value)

  /// Replaces component-local serialized state and returns the updated handle.
  api fn update_serialized(self, value: MsgPack): Component -> StateHandle<MsgPack>
    Component::state_set(self.id, value)
    StateHandle<MsgPack> { id: self.id, value: value }

impl StateHandle<String>
  /// Replaces component-local text state and schedules the component runtime.
  api fn set(self, value: String): Component -> void
    Component::state_set(self.id, msgpack::make_string(value))

  api fn set(self, value: StringSlice): Component -> void
    self.set(value.to_string())

  /// Replaces component-local text state and returns the updated handle.
  api fn update(self, value: String): Component -> StateHandle<String>
    Component::state_set(self.id, msgpack::make_string(value))
    StateHandle<String> { id: self.id, value: value }

  api fn update(self, value: StringSlice): Component -> StateHandle<String>
    self.update(value.to_string())

impl StateHandle<i32>
  /// Replaces component-local integer state and schedules the component runtime.
  api fn set(self, value: i32): Component -> void
    Component::state_set(self.id, msgpack::make_i32(value))

  /// Replaces component-local integer state and returns the updated handle.
  api fn update(self, value: i32): Component -> StateHandle<i32>
    Component::state_set(self.id, msgpack::make_i32(value))
    StateHandle<i32> { id: self.id, value: value }

impl<Msg> Cmd<Msg>
  /// Creates an empty command.
  api fn none() -> Cmd<Msg>
    Cmd<Msg> { payload: command_payload("none") }

  /// Creates a command that dispatches a serialized host/runtime message.
  api fn message_serialized(value: MsgPack) -> Cmd<Msg>
    let ~out = command_map("message")
    out.set("value", value)
    Cmd<Msg> { payload: msgpack::make_map(out) }

  /// Creates a command that dispatches a typed application message.
  api fn message(value: Msg) -> Cmd<Msg>
    let ~out = command_map("message")
    out.set("value", boundary_value_to_msgpack(value))
    Cmd<Msg> { payload: msgpack::make_map(out) }

  /// Creates a command batch from existing command values.
  api fn batch(values: Array<Cmd<Msg>>) -> Cmd<Msg>
    let ~children = Array<MsgPack>::with_capacity(values.len())
    var index = 0
    while index < values.len():
      let value = values.at(index)
      children.push(value.payload)
      index = index + 1

    let ~out = command_map("batch")
    out.set("children", msgpack::make_array(children))
    Cmd<Msg> { payload: msgpack::make_map(out) }

  /// Lifts a child command through a retained message mapper.
  api fn map<NextMsg>(self, { handler_id: i32 }) -> Cmd<NextMsg>
    let ~out = command_map("map")
    out.set("child", self.payload)
    out.set("handlerId", msgpack::make_i32(handler_id))
    Cmd<NextMsg> { payload: msgpack::make_map(out) }

  /// Lifts a child command through a retained serialized message mapper.
  api fn map_serialized<NextMsg>(self, handler: fn(MsgPack) -> MsgPack) -> Cmd<NextMsg>
    self.map<NextMsg>(handler_id: retain_message_mapper(handler))

  /// Lifts a child command through a retained typed message mapper.
  api fn map<NextMsg>(self, handler: fn(Msg) -> NextMsg) -> Cmd<NextMsg>
    self.map<NextMsg>(handler_id: retain_typed_message_mapper(handler))

  /// Creates a host/runtime command envelope for a registered VX command executor.
  api fn runtime({ kind: String, value?: MsgPack }) -> Cmd<Msg>
    let ~out = command_map(kind)
    if value is Some:
      out.set("value", value.value)
    Cmd<Msg> { payload: msgpack::make_map(out) }

  api fn runtime({ kind: StringSlice, value?: MsgPack }) -> Cmd<Msg>
    Cmd<Msg>::runtime(kind: kind.to_string(), value: value)

  /// Creates a task command envelope for a retained result mapper.
  api fn perform({ task_id: i32, handler_id: i32 }) -> Cmd<Msg>
    let ~out = command_map("task")
    out.set("taskId", msgpack::make_i32(task_id))
    out.set("handlerId", msgpack::make_i32(handler_id))
    Cmd<Msg> { payload: msgpack::make_map(out) }

  /// Creates a task command envelope for a retained Voyd result mapper.
  api fn perform({ task_id: i32, handler: fn(MsgPack) -> MsgPack }) -> Cmd<Msg>
    Cmd<Msg>::perform(task_id: task_id, handler_id: retain_message_mapper(handler))

  /// Creates a task command envelope for a retained typed result mapper.
  api fn perform<T>({ task_id: i32, handler: fn(T) -> Msg }) -> Cmd<Msg>
    Cmd<Msg>::perform(task_id: task_id, handler_id: retain_typed_message_mapper(handler))

  /// Creates a task command envelope from a Voyd task and retained result mapper.
  api fn perform<T>({ task: Task<T>, handler_id: i32 }) -> Cmd<Msg>
    let ~out = command_map("task")
    out.set("taskId", msgpack::make_i32(task.id))
    out.set("handlerId", msgpack::make_i32(handler_id))
    Cmd<Msg> { payload: msgpack::make_map(out) }

  /// Creates a task command envelope from a Voyd task and retained result mapper.
  api fn perform<T>({ task: Task<T>, handler: fn(MsgPack) -> MsgPack }) -> Cmd<Msg>
    Cmd<Msg>::perform<T>(task: task, handler_id: retain_message_mapper(handler))

  /// Creates a task command envelope from a Voyd task and retained typed result mapper.
  api fn perform<T>({ task: Task<T>, handler: fn(T) -> Msg }) -> Cmd<Msg>
    Cmd<Msg>::perform<T>(task: task, handler_id: retain_typed_message_mapper(handler))

  /// Creates a timer command that dispatches a serialized value after the delay.
  api fn delay_serialized({ millis: i64, value: MsgPack }) -> Cmd<Msg>
    let ~out = command_map("delay")
    out.set("ms", msgpack::make_i64(millis))
    out.set("value", value)
    Cmd<Msg> { payload: msgpack::make_map(out) }

  /// Creates a timer command that dispatches a typed message after the delay.
  api fn delay({ millis: i64, value: Msg }) -> Cmd<Msg>
    let ~out = command_map("delay")
    out.set("ms", msgpack::make_i64(millis))
    out.set("value", boundary_value_to_msgpack(value))
    Cmd<Msg> { payload: msgpack::make_map(out) }

  /// Creates a DOM focus command for a constrained VX ref.
  api fn focus<T>(target: Ref<T>) -> Cmd<Msg>
    Cmd<Msg>::runtime(kind: "focus", value: msgpack::make_string(target.id))

  /// Creates a scroll-into-view command for a constrained VX ref.
  api fn scroll_into_view<T>(target: Ref<T>) -> Cmd<Msg>
    Cmd<Msg>::runtime(kind: "scroll_into_view", value: msgpack::make_string(target.id))

impl<Msg> Sub<Msg>
  /// Creates an empty subscription set.
  api fn none() -> Sub<Msg>
    Sub<Msg> { payload: subscription_payload("none") }

  /// Creates a subscription batch from existing subscription values.
  api fn batch(values: Array<Sub<Msg>>) -> Sub<Msg>
    let ~children = Array<MsgPack>::with_capacity(values.len())
    var index = 0
    while index < values.len():
      let value = values.at(index)
      children.push(value.payload)
      index = index + 1

    let ~out = subscription_map("batch")
    out.set("children", msgpack::make_array(children))
    Sub<Msg> { payload: msgpack::make_map(out) }

  /// Lifts a child subscription through a retained message mapper.
  api fn map<NextMsg>(self, { handler_id: i32 }) -> Sub<NextMsg>
    let ~out = subscription_map("map")
    out.set("child", self.payload)
    out.set("handlerId", msgpack::make_i32(handler_id))
    Sub<NextMsg> { payload: msgpack::make_map(out) }

  /// Lifts a child subscription through a retained serialized message mapper.
  api fn map_serialized<NextMsg>(self, handler: fn(MsgPack) -> MsgPack) -> Sub<NextMsg>
    self.map<NextMsg>(handler_id: retain_message_mapper(handler))

  /// Lifts a child subscription through a retained typed message mapper.
  api fn map<NextMsg>(self, handler: fn(Msg) -> NextMsg) -> Sub<NextMsg>
    self.map<NextMsg>(handler_id: retain_typed_message_mapper(handler))

  /// Creates a host/runtime subscription envelope for a registered VX subscription runner.
  api fn runtime({ kind: String, key: String, value?: MsgPack }) -> Sub<Msg>
    let ~out = subscription_map(kind)
    out.set("key", key)
    if value is Some:
      out.set("value", value.value)
    Sub<Msg> { payload: msgpack::make_map(out) }

  api fn runtime({ kind: StringSlice, key: StringSlice, value?: MsgPack }) -> Sub<Msg>
    Sub<Msg>::runtime(kind: kind.to_string(), key: key.to_string(), value: value)

  /// Creates an interval subscription envelope for a serialized host runtime value.
  api fn every_serialized({ key: String, millis: i64, value: MsgPack }) -> Sub<Msg>
    let ~out = subscription_map("interval")
    out.set("key", key)
    out.set("ms", msgpack::make_i64(millis))
    out.set("value", value)
    Sub<Msg> { payload: msgpack::make_map(out) }

  /// Creates an interval subscription that dispatches a typed message.
  api fn every({ key: String, millis: i64, value: Msg }) -> Sub<Msg>
    let ~out = subscription_map("interval")
    out.set("key", key)
    out.set("ms", msgpack::make_i64(millis))
    out.set("value", boundary_value_to_msgpack(value))
    Sub<Msg> { payload: msgpack::make_map(out) }

  api fn every_serialized({ key: StringSlice, millis: i64, value: MsgPack }) -> Sub<Msg>
    Sub<Msg>::every_serialized(key: key.to_string(), millis: millis, value: value)

  api fn every({ key: StringSlice, millis: i64, value: Msg }) -> Sub<Msg>
    Sub<Msg>::every(key: key.to_string(), millis: millis, value: value)

/// Subscribes to global keydown events through the browser VX runtime host.
pub fn keyboard_on_key_down_serialized<Msg>({ key: String, value: MsgPack }) -> Sub<Msg>
  keyboard_subscription(kind: "keydown", key: key, value: value)

pub fn keyboard_on_key_down<Msg>({ key: String, value: Msg }) -> Sub<Msg>
  keyboard_subscription(kind: "keydown", key: key, value: boundary_value_to_msgpack(value))

pub fn keyboard_on_key_down_serialized<Msg>({ key: StringSlice, value: MsgPack }) -> Sub<Msg>
  keyboard_on_key_down_serialized<Msg>(key: key.to_string(), value: value)

pub fn keyboard_on_key_down<Msg>({ key: StringSlice, value: Msg }) -> Sub<Msg>
  keyboard_on_key_down<Msg>(key: key.to_string(), value: value)

/// Subscribes to global keyup events through the browser VX runtime host.
pub fn keyboard_on_key_up_serialized<Msg>({ key: String, value: MsgPack }) -> Sub<Msg>
  keyboard_subscription(kind: "keyup", key: key, value: value)

pub fn keyboard_on_key_up<Msg>({ key: String, value: Msg }) -> Sub<Msg>
  keyboard_subscription(kind: "keyup", key: key, value: boundary_value_to_msgpack(value))

pub fn keyboard_on_key_up_serialized<Msg>({ key: StringSlice, value: MsgPack }) -> Sub<Msg>
  keyboard_on_key_up_serialized<Msg>(key: key.to_string(), value: value)

pub fn keyboard_on_key_up<Msg>({ key: StringSlice, value: Msg }) -> Sub<Msg>
  keyboard_on_key_up<Msg>(key: key.to_string(), value: value)

/// Reads a component-local serialized state handle.
pub fn state_handle({
  initial: MsgPack,
  id: i32 = stable_callsite_id()
}): Component -> StateHandle<MsgPack>
  state_handle_at(id: id, initial: initial)

fn state_handle_at({ id: i32, initial: MsgPack }): Component -> StateHandle<MsgPack>
  let slot = Component::state_key(id)
  StateHandle<MsgPack> {
    id: slot,
    value: Component::state_get(slot, initial)
  }

/// Reads a component-local text state handle.
pub fn state_handle({
  initial: String,
  id: i32 = stable_callsite_id()
}): Component -> StateHandle<String>
  state_handle_at(id: id, initial: initial)

fn state_handle_at({ id: i32, initial: String }): Component -> StateHandle<String>
  let slot = Component::state_key(id)
  StateHandle<String> {
    id: slot,
    value: component_string_state_value(
      value: Component::state_get(slot, msgpack::make_string(initial)),
      fallback: initial
    )
  }

pub fn state_handle({
  initial: StringSlice,
  id: i32 = stable_callsite_id()
}): Component -> StateHandle<String>
  state_handle_at(id: id, initial: initial.to_string())

/// Reads a component-local integer state handle.
pub fn state_handle({
  initial: i32,
  id: i32 = stable_callsite_id()
}): Component -> StateHandle<i32>
  state_handle_at(id: id, initial: initial)

fn state_handle_at({ id: i32, initial: i32 }): Component -> StateHandle<i32>
  let slot = Component::state_key(id)
  StateHandle<i32> {
    id: slot,
    value: component_i32_state_value(
      value: Component::state_get(slot, msgpack::make_i32(initial)),
      fallback: initial
    )
  }

/// Reads component-local serialized state as a `(value, setter)` pair.
pub fn state({
  initial: MsgPack,
  id: i32 = stable_callsite_id()
}): Component -> (MsgPack, fn(MsgPack) -> void)
  let handle = state_handle_at(id: id, initial: initial)
  (handle.value, (value: MsgPack) -> void => handle.set_serialized(value))

/// Reads component-local text state as a `(value, setter)` pair.
pub fn state({
  initial: String,
  id: i32 = stable_callsite_id()
}): Component -> (String, fn(String) -> void)
  let handle = state_handle_at(id: id, initial: initial)
  (handle.value, (value: String) -> void => handle.set(value))

pub fn state({
  initial: StringSlice,
  id: i32 = stable_callsite_id()
}): Component -> (String, fn(String) -> void)
  let handle = state_handle_at(id: id, initial: initial.to_string())
  (handle.value, (value: String) -> void => handle.set(value))

/// Reads component-local integer state as a `(value, setter)` pair.
pub fn state({
  initial: i32,
  id: i32 = stable_callsite_id()
}): Component -> (i32, fn(i32) -> void)
  let handle = state_handle_at(id: id, initial: initial)
  (handle.value, (value: i32) -> void => handle.set(value))

fn component_string_state_value({ value: MsgPack, fallback: String }): () -> String
  match(msgpack::unpack_string(value))
    Ok<String> { value }:
      value
    Err:
      fallback

fn component_i32_state_value({ value: MsgPack, fallback: i32 }): () -> i32
  match(msgpack::unpack_i32(value))
    Ok<i32> { value }:
      value
    Err:
      fallback

/// Registers a task with the current component instance.
pub fn task<T>({ key: MsgPack, task: Task<T> }): Component -> Unit
  Component::task_started(key, task.id)
  Unit {}

/// Retains a pure Voyd event callback in the host and returns its DOM handler id.
pub fn retain_event_handler(handler: fn() -> MsgPack): () -> i32
  retain_event_handler_id(handler)

/// Retains a component-local effect callback that does not dispatch an app message.
pub fn retain_event_handler(handler: fn() -> void): () -> i32
  retain_event_handler_void_id(handler)

/// Retains a pure Voyd event callback that receives the normalized event payload.
pub fn retain_event_payload_handler(handler: fn(MsgPack) -> MsgPack): () -> i32
  retain_event_handler_with_payload_id(handler)

/// Retains a pure Voyd message mapper for commands, subscriptions, or events.
pub fn retain_message_mapper(handler: fn(MsgPack) -> MsgPack): () -> i32
  retain_event_handler_with_payload_id(handler)

/// Retains a pure typed Voyd event callback in the host and returns its DOM handler id.
pub fn retain_typed_event_handler<Msg>(handler: fn() -> Msg): () -> i32
  retain_typed_event_handler_id(handler)

/// Retains a pure typed Voyd event callback that receives the normalized event payload.
pub fn retain_typed_event_payload_handler<Event, Msg>(handler: fn(Event) -> Msg): () -> i32
  retain_typed_event_handler_with_payload_id(handler)

/// Retains a pure typed Voyd message mapper for commands, subscriptions, or events.
pub fn retain_typed_message_mapper<From, To>(handler: fn(From) -> To): () -> i32
  retain_typed_event_handler_with_payload_id(handler)

/// Creates a versioned VX render frame.
pub fn frame(root: MsgPack): () -> MsgPack
  let ~out = Dict<String, MsgPack>::init()
  out.set("version", msgpack::make_i32(1))
  out.set("root", root)
  msgpack::make_map(out)

/// Creates a VX text node.
pub fn text(value: String): () -> MsgPack
  let ~out = Dict<String, MsgPack>::init()
  out.set("kind", "text")
  out.set("value", value)
  msgpack::make_map(out)

/// Creates a VX text node from a string slice.
pub fn text(value: StringSlice): () -> MsgPack
  text(value.to_string())

/// Creates a VX fragment node.
pub fn fragment(children: Array<MsgPack>): () -> MsgPack
  let ~out = Dict<String, MsgPack>::init()
  out.set("kind", "fragment")
  out.set("children", children)
  msgpack::make_map(out)

/// Creates a VX element node using the versioned renderer schema.
pub fn element({
  tag: String,
  attrs?: Array<MsgPack>,
  children: Array<MsgPack>
}) -> MsgPack
  let ~out = Dict<String, MsgPack>::init()
  out.set("kind", "element")
  out.set("tag", tag)
  out.set("children", children)
  if attrs is Some:
    let normalized = normalize_attrs(attrs.value)
    if normalized.attrs.len() > 0:
      out.set("attrs", msgpack::make_map(normalized.attrs))
    if normalized.props.len() > 0:
      out.set("props", msgpack::make_map(normalized.props))
    if normalized.styles.len() > 0:
      out.set("styles", msgpack::make_map(normalized.styles))
    if normalized.events.len() > 0:
      out.set("events", normalized.events)
  msgpack::make_map(out)

pub fn html_element({
  tag: String,
  attrs?: Array<HtmlAttr>,
  children: Array<HtmlNode>
}) -> HtmlNode
  element(tag: tag, attrs: attrs, children: children)

/// Creates a string-valued DOM attribute.
pub fn attr({ name: String, value: String }): () -> MsgPack
  let ~out = Dict<String, MsgPack>::init()
  out.set("kind", "attr")
  out.set("name", name)
  out.set("value", value)
  msgpack::make_map(out)

pub fn attr({ name: String, value: bool }): () -> MsgPack
  let ~out = Dict<String, MsgPack>::init()
  out.set("kind", "attr")
  out.set("name", name)
  out.set("value", msgpack::make_bool(value))
  msgpack::make_map(out)

pub fn attr({ name: String, value: i32 }): () -> MsgPack
  let ~out = Dict<String, MsgPack>::init()
  out.set("kind", "attr")
  out.set("name", name)
  out.set("value", msgpack::make_i32(value))
  msgpack::make_map(out)

pub fn attr({ name: StringSlice, value: String }): () -> MsgPack
  attr(name: name.to_string(), value: value)

pub fn attr({ name: StringSlice, value: bool }): () -> MsgPack
  attr(name: name.to_string(), value: value)

pub fn attr({ name: StringSlice, value: i32 }): () -> MsgPack
  attr(name: name.to_string(), value: value)

pub fn attr({ name: String, value: StringSlice }): () -> MsgPack
  attr(name: name, value: value.to_string())

pub fn attr({ name: StringSlice, value: StringSlice }): () -> MsgPack
  attr(name: name.to_string(), value: value.to_string())

pub fn id(value: String): () -> MsgPack
  attr(name: "id", value: value)

pub fn id(value: StringSlice): () -> MsgPack
  id(value.to_string())

pub fn class(value: String): () -> MsgPack
  attr(name: "class", value: value)

pub fn class(value: StringSlice): () -> MsgPack
  class(value.to_string())

pub fn classes(values: Array<String>): () -> MsgPack
  class(join_classes(values))

pub fn role(value: String): () -> MsgPack
  attr(name: "role", value: value)

pub fn role(value: StringSlice): () -> MsgPack
  role(value.to_string())

pub fn name(value: String): () -> MsgPack
  attr(name: "name", value: value)

pub fn name(value: StringSlice): () -> MsgPack
  name(value.to_string())

pub fn placeholder(value: String): () -> MsgPack
  attr(name: "placeholder", value: value)

pub fn placeholder(value: StringSlice): () -> MsgPack
  placeholder(value.to_string())

pub fn input_type(value: String): () -> MsgPack
  attr(name: "type", value: value)

pub fn input_type(value: StringSlice): () -> MsgPack
  input_type(value.to_string())

pub fn tab_index(value: i32): () -> MsgPack
  attr(name: "tabindex", value: value)

pub fn ref<T>(target: Ref<T>): () -> MsgPack
  attr(name: "data-vx-ref", value: target.id)

pub fn value(value: String): () -> MsgPack
  prop(name: "value", value: value)

pub fn value(value: StringSlice): () -> MsgPack
  prop(name: "value", value: value.to_string())

pub fn disabled(value: bool): () -> MsgPack
