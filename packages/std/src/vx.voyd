pub fn program<Model, Msg>({
  model: Model,
  frame?: Html<Msg>,
  commands?: Cmd<Msg>,
  subscriptions?: Sub<Msg>
}) -> Program<Model, Msg>
  let ~out = Dict<String, MsgPack>::init()
  out.set("$vx", "runtime_result")
  out.set("model", boundary_value_to_msgpack(model))
  if frame is Some:
    out.set("frame", frame.value)
  if commands is Some:
    out.set("commands", commands.value.payload)
  if subscriptions is Some:
    out.set("subscriptions", subscriptions.value.payload)
  msgpack::make_map(out)

pub fn program<Model, Msg>({
  init: fn() -> Model,
  update: fn(Model, Msg) -> Program<Model, Msg>,
  view: fn(Model) -> Html<Msg>
}) -> Program<Model, Msg>
  program_handlers<Model, Msg>(
    init_id: __retain_callback(init),
    update_id: __retain_callback(update),
    view_id: __retain_callback(view)
  )

pub fn program<Model, Msg>({
  init: fn() -> Program<Model, Msg>,
  update: fn(Model, Msg) -> Program<Model, Msg>,
  view: fn(Model) -> Html<Msg>
}) -> Program<Model, Msg>
  program_handlers<Model, Msg>(
    init_id: __retain_callback(init),
    update_id: __retain_callback(update),
    view_id: __retain_callback(view)
  )

pub fn program<Model, Msg>({
  init: fn() -> Model,
  update: fn(Model, Msg) -> Program<Model, Msg>,
  view: fn(Model) -> Html<Msg>,
  subscriptions: fn(Model) -> Sub<Msg>
}) -> Program<Model, Msg>
  program_handlers<Model, Msg>(
    init_id: __retain_callback(init),
    update_id: __retain_callback(update),
    view_id: __retain_callback(view),
    subscriptions_id: __retain_callback(subscriptions)
  )

pub fn program<Model, Msg>({
  init: fn() -> Program<Model, Msg>,
  update: fn(Model, Msg) -> Program<Model, Msg>,
  view: fn(Model) -> Html<Msg>,
  subscriptions: fn(Model) -> Sub<Msg>
}) -> Program<Model, Msg>
  program_handlers<Model, Msg>(
    init_id: __retain_callback(init),
    update_id: __retain_callback(update),
    view_id: __retain_callback(view),
    subscriptions_id: __retain_callback(subscriptions)
  )

fn program_handlers<Model, Msg>({
  init_id: i32,
  update_id: i32,
  view_id: i32,
  subscriptions_id?: i32
}) -> Program<Model, Msg>
  let ~out = Dict<String, MsgPack>::init()
  out.set("kind", "program")
  out.set("initHandlerId", msgpack::make_i32(init_id))
  out.set("updateHandlerId", msgpack::make_i32(update_id))
  out.set("viewHandlerId", msgpack::make_i32(view_id))
  if subscriptions_id is Some:
    out.set("subscriptionsHandlerId", msgpack::make_i32(subscriptions_id.value))
  msgpack::make_map(out)

/// Creates a virtual DOM element payload for renderer consumption.
///
/// The returned value is a MsgPack map with `name`, `children`, and optional `attributes`.
pub fn create_element({
  /// Element tag or component identifier.
  name: String,
  /// Optional list of two-item key/value MsgPack pairs.
  attributes?: Array<Array<MsgPack>>,
  /// Ordered child node payloads.
  children: Array<MsgPack>
}) -> MsgPack
  let ~element = Dict<String, MsgPack>::init()
  element.set("name", name)
  element.set("children", children)
  if attributes is Some:
    let attrs = attributes_to_map(attributes.value)
    element.set("attributes", msgpack::make_map(attrs))
  msgpack::make_map(element)

obj NormalizedAttrs {
  attrs: Dict<String, MsgPack>,
  props: Dict<String, MsgPack>,
  styles: Dict<String, MsgPack>,
  events: Array<MsgPack>
}

fn normalize_attrs(attributes: Array<MsgPack>): () -> NormalizedAttrs
  let ~attrs = Dict<String, MsgPack>::init()
  let ~props = Dict<String, MsgPack>::init()
  let ~styles = Dict<String, MsgPack>::init()
  let ~events = Array<MsgPack>::init()
  var index = 0
  while index < attributes.len():
    match(attributes.get(index))
      Some<MsgPack> { value }:
        match(msgpack::unpack_map(value))
          Ok<Dict<String, MsgPack>> { value: entry }:
            consume_attr_entry(entry, attrs, props, styles, events)
          Err:
            void
      None:
        void
    index = index + 1
  NormalizedAttrs { attrs: attrs, props: props, styles: styles, events: events }

fn consume_attr_entry(
  entry: Dict<String, MsgPack>,
  ~attrs: Dict<String, MsgPack>,
  ~props: Dict<String, MsgPack>,
  ~styles: Dict<String, MsgPack>,
  ~events: Array<MsgPack>
) -> void
  match(entry.get("kind"))
    Some<MsgPack> { value }:
      match(msgpack::unpack_string(value))
        Ok<String> { value: kind }:
          if kind == "event":
            events.push(msgpack::make_map(entry))
          else:
            if kind == "style":
              consume_named_attr(entry, styles)
            else:
              if kind == "prop":
                consume_named_attr(entry, props)
              else:
                consume_named_attr(entry, attrs)
        Err:
          void
    None:
      void

fn consume_named_attr(entry: Dict<String, MsgPack>, ~attrs: Dict<String, MsgPack>) -> void
  match(entry.get("name"))
    Some<MsgPack> { value }:
      match(msgpack::unpack_string(value))
        Ok<String> { value: name }:
          match(entry.get("value"))
            Some<MsgPack> { value: attr_value }:
              attrs.set(name, attr_value)
            None:
              void
        Err:
          void
    None:
      void

fn bool_attr({ name: String, value: bool }): () -> MsgPack
  named_value("attr", name, msgpack::make_bool(value))

fn named_value(kind: String, name: String, value: MsgPack): () -> MsgPack
  let ~out = Dict<String, MsgPack>::init()
  out.set("kind", kind)
  out.set("name", name)
  out.set("value", value)
  msgpack::make_map(out)

fn named_value(kind: String, name: String, value: String): () -> MsgPack
  named_value(kind, name, msgpack::make_string(value))

fn join_classes(values: Array<String>): () -> String
  var out = String::init()
  var index = 0
  while index < values.len():
    match(values.get(index))
      Some<String> { value }:
        if out.byte_len() == 0:
          out = value
        else:
          out = out.concat(" ").concat(value)
      None:
        void
    index = index + 1
  out

fn event_options_to_map(options: EventOptions): () -> Dict<String, MsgPack>
  let ~out = Dict<String, MsgPack>::init()
  set_bool_option(out, "preventDefault", options.prevent_default)
  set_bool_option(out, "stopPropagation", options.stop_propagation)
  set_bool_option(out, "capture", options.capture)
  set_bool_option(out, "passive", options.passive)
  out

fn set_bool_option(~out: Dict<String, MsgPack>, name: String, value: Optional<bool>) -> void
  match(value)
    Some<bool> { value }:
      out.set(name, msgpack::make_bool(value))
    None:
      void

fn command_payload(kind: String): () -> MsgPack
  msgpack::make_map(command_map(kind))

fn command_map(kind: String): () -> Dict<String, MsgPack>
  tagged_vx_runtime_map("cmd", kind)

fn subscription_payload(kind: String): () -> MsgPack
  msgpack::make_map(subscription_map(kind))

fn subscription_map(kind: String): () -> Dict<String, MsgPack>
  tagged_vx_runtime_map("sub", kind)

fn keyboard_subscription<Msg>({ kind: String, key: String, value: MsgPack }) -> Sub<Msg>
  let ~out = subscription_map("keyboard")
  out.set("key", key)
  out.set("event", kind)
  out.set("value", value)
  Sub<Msg> { payload: msgpack::make_map(out) }

fn tagged_vx_runtime_map(type_name: String, kind: String): () -> Dict<String, MsgPack>
  let ~out = Dict<String, MsgPack>::init()
  out.set("type", type_name)
  out.set("kind", kind)
  out

fn attributes_to_map(attributes: Array<Array<MsgPack>>): () -> Dict<String, MsgPack>
  let ~acc = Dict<String, MsgPack>::init()
  var index = 0
  while index < attributes.len():
    match(attributes.get(index))
      Some<Array<MsgPack>> { value: pair }:
        match(pair.get(0))
          Some<MsgPack> { value: key }:
            match(pair.get(1))
              Some<MsgPack> { value: value }:
                match(msgpack::unpack_string(key))
                  Ok<String> { value: name }:
                    acc.set(name, value)
                  Err:
                    panic("vx attribute key must decode as string".as_slice())
              None:
                void
          None:
            void
      None:
        void
    index = index + 1
  acc
