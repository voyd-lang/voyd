fn assert_variant(value: MsgPack, expected: StringSlice) -> void
  match(msgpack::unpack_map(value))
    Ok<Dict<String, MsgPack>> { value: variant_map }:
      assert_string_field(variant_map, "$variant".as_slice(), expected)
    Err:
      assert(false, eq: true)

fn assert_variant(value: MsgPack, expected: String) -> void
