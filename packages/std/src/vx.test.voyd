    Ok<Dict<String, MsgPack>> { value }:
      match(value.get(field.to_string()))
        Some<MsgPack>:
          assert(true, eq: true)
        None:
          assert(false, eq: true)
    Err:
      assert(false, eq: true)

fn assert_payload_has_field(payload: MsgPack, field: String) -> void
