pub fn explicit_event_id_survives_ssr_probe() -> i32
  let handler_id = retain_typed_event_handler<i32>(() -> i32 => 42)
  let explicit_view: Html<i32> = element(
    tag: "button",
    attrs: [event(name: "click", handler_id: handler_id)],
    children: [text("Explicit")]
  )
  let _ = document(explicit_view)
  handler_id

fn render_scoped_response(request: IncomingRequest) -> Response
  if request.path.equals("/hydrate-fail"):
    return Response::ok().text(direct_hydration_failure_probe())
  if request.path.equals("/static"):
    let static_view: Html<MsgPack> = <button on_click={msgpack::make_string("clicked")}>Static</button>
    return Response::ok().text(document(static_view))

  Response::ok().text(document(retained_ssr_view(request.path.equals("/fail"))))

fn retained_ssr_view(invalid: bool) -> Html<MsgPack>
  let attrs = [
    event_payload_handler<InputEvent, MsgPack>(
      name: "input",
      handler: (event: InputEvent) -> MsgPack => msgpack::make_string(event.value)
    )
  ]
  let tag = if invalid then: "input" else: "button"
  element(tag: tag, attrs: attrs, children: [text("Rendered")])

fn typed_retained_ssr_view() -> Html<SsrMsg>
  <textarea on_input={(event: InputEvent) -> SsrMsg => SsrMsg::Edit { value: event.value }}>Typed</textarea>

fn failing_ssr_view() -> Html<MsgPack>
  let retained = retained_ssr_view(false)
  panic("view evaluation failed")
  retained
