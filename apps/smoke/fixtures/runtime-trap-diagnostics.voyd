use std::error::panic

@effect(id: "com.example.trap")
eff TrapFx
  denom(resume, value: i32) -> i32

fn zero() -> i32
  0

pub fn pure_trap() -> i32
  10 / zero()

pub fn effectful_trap(): TrapFx -> i32
  let denominator = TrapFx::denom(1)
  10 / denominator

pub fn panic_trap() -> void
  panic("panic with context")

pub fn panic_slice_trap() -> void
  panic("slice panic with context".as_slice())
