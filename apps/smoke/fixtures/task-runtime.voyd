  events.len()

pub fn attached_failure_probe(): task::TaskRuntime -> i32
  let _ = task::spawn(() =>
    panic("attached child failed".as_slice())
  )
  1

pub fn detached_failure_probe(): task::TaskRuntime -> i32
  let _ = task::detach(() =>
    panic("detached child failed".as_slice())
  )
  1
