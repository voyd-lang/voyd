{
  "name": "@voyd-lang/cli",
  "version": "0.1.0",
  "private": false,
  "description": "Voyd CLI",
  "type": "module",
  "bin": {
    "voyd": "./bin/voyd.js",
    "vt": "./bin/voyd.js"
  },
  "files": [
    "bin",
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run --config ../../vitest.config.ts --testTimeout 60000 src/__tests__",
    "lint": "echo 'no lint configured'",
    "prepack": "npm run clean && npm run build",
    "prepublishOnly": "node ../../scripts/release/enforce-workspace-release.mjs"
  },
  "dependencies": {
    "@voyd-lang/sdk": "^0.1.0",
    "@voyd-lang/lib": "^0.1.0",
    "@voyd-lang/std": "^0.1.0",
    "binaryen": "^125.0.0",
    "commander": "^14.0.0"
  }
}
