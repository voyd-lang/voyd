{
  "name": "mini-wikipedia",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx --conditions=development scripts/dev.mjs",
    "build": "vite build && npm run voyd:check",
    "start": "tsx --conditions=development scripts/serve.mjs",
    "test": "voyd test src/wiki.test.voyd",
    "voyd:check": "tsx --conditions=development scripts/check-voyd.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@voyd-lang/sdk": "^0.2.0",
    "@voyd-lang/vx-dom": "^0.2.0",
    "@voyd-lang/web": "^0.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.5.1",
    "@voyd-lang/cli": "^0.2.0",
    "tsx": "^4.20.4",
    "typescript": "^5.8.3",
    "vite": "^8.0.0"
  }
}
